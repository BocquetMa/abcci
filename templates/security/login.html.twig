{% extends 'base.html.twig' %}

{% block title %}Connexion - ABCCI Formation{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body {
            background-color: #f6f6f6;
        }
        .login-page {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }
        .login-brand {
            text-align: center;
            margin-bottom: 2rem;
        }
        .login-brand .fr-logo {
            display: inline-block;
            margin-bottom: 1rem;
        }
        .login-brand h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #003189;
            margin-bottom: 0.25rem;
        }
        .login-brand p {
            color: #666;
            font-size: 0.9rem;
            margin: 0;
        }
        .login-card {
            background: white;
            border: 1px solid #e5e5e5;
            border-radius: 4px;
            padding: 2rem;
            width: 100%;
            max-width: 440px;
            box-shadow: 0 2px 6px rgba(0,0,18,0.06);
        }
        .login-card h2 {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1e1e1e;
            margin-bottom: 1.5rem;
            text-align: center;
        }
        .divider-or {
            display: flex;
            align-items: center;
            margin: 1.25rem 0;
            color: #666;
            font-size: 0.85rem;
        }
        .divider-or::before, .divider-or::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e5e5e5;
        }
        .divider-or span {
            padding: 0 0.75rem;
        }
        .google-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            width: 100%;
            padding: 0.65rem 1rem;
            border: 1px solid #ddd;
            border-radius: 4px;
            background: white;
            color: #1e1e1e;
            font-size: 0.9rem;
            font-weight: 500;
            text-decoration: none;
            transition: background 0.2s, border-color 0.2s;
        }
        .google-btn:hover {
            background: #f6f6f6;
            border-color: #aaa;
            color: #1e1e1e;
        }
        .google-btn img {
            width: 20px;
            height: 20px;
        }
        .login-footer {
            text-align: center;
            margin-top: 1.5rem;
            font-size: 0.9rem;
            color: #666;
        }
        .login-footer a {
            color: #003189;
            font-weight: 600;
        }
    </style>
{% endblock %}

{% block body %}
<div class="login-page">
    <div class="login-brand">
        <p class="fr-logo">République<br>Française</p>
        <h1>ABCCI Formation</h1>
        <p>Centre de formation professionnelle</p>
    </div>

    <div class="login-card">
        <h2>Se connecter</h2>

        {% if error %}
            <div class="fr-alert fr-alert--error fr-alert--sm fr-mb-2w" role="alert">
                <p>{{ error.messageKey|trans(error.messageData, 'security') }}</p>
            </div>
        {% endif %}

        <!-- Connexion Google -->
        <a href="{{ path('connect_google_start') }}" class="google-btn">
            <img src="https://upload.wikimedia.org/wikipedia/commons/5/53/Google_%22G%22_Logo.svg" alt="Google">
            Continuer avec Google
        </a>

        <div class="divider-or"><span>ou</span></div>

        <form method="post">
            <div class="fr-input-group">
                <label class="fr-label" for="email">
                    Adresse email
                </label>
                <input class="fr-input"
                       type="email"
                       value="{{ last_username }}"
                       name="email"
                       id="email"
                       autocomplete="email"
                       required
                       autofocus
                       placeholder="votre@email.com">
            </div>

            <div class="fr-input-group">
                <label class="fr-label" for="password">
                    Mot de passe
                </label>
                <div class="fr-password" id="password-input">
                    <input class="fr-password__input fr-input"
                           autocomplete="current-password"
                           type="password"
                           name="password"
                           id="password"
                           required
                           placeholder="••••••••">
                    <div class="fr-password__checkbox fr-checkbox-group fr-checkbox-group--sm">
                        <input aria-label="Afficher le mot de passe" id="toggle-password" type="checkbox" aria-describedby="password-input-messages">
                        <label class="fr-password__checkbox fr-label" for="toggle-password">
                            Afficher
                        </label>
                    </div>
                    <div class="fr-messages-group" id="password-input-messages" aria-live="assertive"></div>
                </div>
            </div>

            <div class="fr-checkbox-group fr-mb-2w">
                <input type="checkbox" id="remember_me" name="_remember_me">
                <label class="fr-label" for="remember_me">Se souvenir de moi</label>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button class="fr-btn w-100" type="submit" style="justify-content:center;">
                Se connecter
            </button>
        </form>
    </div>

    <div class="login-footer">
        Vous n'avez pas de compte ?
        <a href="{{ path('app_register') }}">Créer un compte</a>
    </div>
</div>
{% endblock %}
