<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}ABCCI Formation{% endblock %}</title>
        <link rel="icon" href="{{ asset('favicon.ico') }}" type="image/x-icon">
        <!-- Google Fonts : Inter -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        <!-- Bootstrap CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <!-- DSFR CSS (layout utilities fr-container, fr-grid-row, etc.) -->
        <link href="https://cdn.jsdelivr.net/npm/@gouvfr/dsfr@1.12.1/dist/dsfr.min.css" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/@gouvfr/dsfr@1.12.1/dist/utility/icons/icons.min.css" rel="stylesheet">
        <!-- Font Awesome -->
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

        {% block stylesheets %}
        <style>
            /* ─── Design Tokens SaaS ─────────────────────────────────── */
            :root {
                /* Palette */
                --clr-primary:        #059669;
                --clr-primary-dark:   #065F46;
                --clr-primary-light:  #D1FAE5;
                --clr-primary-muted:  #ECFDF5;
                --clr-danger:         #DC2626;
                --clr-warning:        #D97706;
                --clr-info:           #2563EB;
                --clr-success:        #059669;

                /* Surfaces */
                --clr-bg:             #F3F4F6;
                --clr-surface:        #FFFFFF;
                --clr-nav-bg:         #111827;
                --clr-nav-text:       #D1D5DB;
                --clr-nav-active:     #FFFFFF;

                /* Text */
                --clr-text:           #111827;
                --clr-text-muted:     #6B7280;
                --clr-text-light:     #9CA3AF;

                /* UI */
                --clr-border:         #E5E7EB;
                --shadow-sm:          0 1px 3px 0 rgba(0,0,0,0.10), 0 1px 2px -1px rgba(0,0,0,0.06);
                --shadow-md:          0 4px 6px -1px rgba(0,0,0,0.10), 0 2px 4px -2px rgba(0,0,0,0.06);
                --radius:             10px;
                --radius-sm:          6px;
                --radius-lg:          14px;

                /* Legacy variables pour les templates enfants */
                --primary:            #059669;
                --primary-dark:       #065F46;
                --primary-light:      #D1FAE5;
                --secondary:          #6B7280;
                --success:            #059669;
                --danger:             #DC2626;
                --warning:            #D97706;
                --info:               #2563EB;
                --body-bg:            #F3F4F6;
                --dark:               #111827;
                --border-radius:      10px;
                --box-shadow:         0 1px 3px 0 rgba(0,0,0,0.10);
                --transition:         all 0.2s ease;

                /* Bootstrap overrides */
                --bs-primary:         #059669;
                --bs-primary-rgb:     5, 150, 105;
                --bs-link-color:      #059669;
                --bs-link-color-rgb:  5, 150, 105;
                --bs-link-hover-color: #065F46;
                --bs-border-radius:   10px;
                --bs-body-font-family: 'Inter', system-ui, -apple-system, sans-serif;
                --bs-body-color:      #111827;
                --bs-body-bg:         #F3F4F6;
            }

            /* ─── Base ───────────────────────────────────────────────── */
            *, *::before, *::after { box-sizing: border-box; }

            body {
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                background-color: var(--clr-bg);
                color: var(--clr-text);
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                font-size: 0.9375rem;
                line-height: 1.6;
                -webkit-font-smoothing: antialiased;
            }

            a { color: var(--clr-primary); text-decoration: none; }
            a:hover { color: var(--clr-primary-dark); }

            /* ─── Topbar ─────────────────────────────────────────────── */
            .app-topbar {
                position: sticky;
                top: 0;
                z-index: 1000;
                background: var(--clr-nav-bg);
                border-bottom: 1px solid rgba(255,255,255,0.06);
                box-shadow: 0 1px 4px rgba(0,0,0,0.25);
            }

            .app-topbar-inner {
                display: flex;
                align-items: center;
                gap: 1rem;
                padding: 0 1.5rem;
                height: 60px;
            }

            /* Logo */
            .app-brand {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                text-decoration: none;
                flex-shrink: 0;
            }
            .app-brand-icon {
                width: 32px;
                height: 32px;
                background: var(--clr-primary);
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1rem;
                color: white;
            }
            .app-brand-name {
                font-size: 1rem;
                font-weight: 700;
                color: #FFFFFF;
                letter-spacing: -0.01em;
            }
            .app-brand-tag {
                font-size: 0.65rem;
                font-weight: 500;
                color: var(--clr-primary);
                background: rgba(5, 150, 105, 0.15);
                padding: 0.1rem 0.45rem;
                border-radius: 100px;
                letter-spacing: 0.04em;
            }

            /* Nav links */
            .app-nav {
                display: flex;
                align-items: center;
                gap: 0.125rem;
                list-style: none;
                margin: 0;
                padding: 0;
                flex: 1;
            }
            .app-nav-link {
                display: flex;
                align-items: center;
                gap: 0.4rem;
                padding: 0.45rem 0.85rem;
                border-radius: var(--radius-sm);
                font-size: 0.85rem;
                font-weight: 500;
                color: var(--clr-nav-text);
                text-decoration: none;
                transition: background 0.15s, color 0.15s;
                white-space: nowrap;
            }
            .app-nav-link:hover {
                background: rgba(255,255,255,0.07);
                color: var(--clr-nav-active);
            }
            .app-nav-link.active {
                background: rgba(5,150,105,0.2);
                color: #6EE7B7;
            }
            .app-nav-link i { font-size: 0.8rem; opacity: 0.8; }

            /* Dropdown nav */
            .app-nav-dropdown { position: relative; }
            .app-nav-dropdown-btn {
                display: flex;
                align-items: center;
                gap: 0.4rem;
                padding: 0.45rem 0.85rem;
                border-radius: var(--radius-sm);
                font-size: 0.85rem;
                font-weight: 500;
                color: var(--clr-nav-text);
                background: none;
                border: none;
                cursor: pointer;
                transition: background 0.15s, color 0.15s;
                white-space: nowrap;
            }
            .app-nav-dropdown-btn:hover,
            .app-nav-dropdown:hover .app-nav-dropdown-btn {
                background: rgba(255,255,255,0.07);
                color: var(--clr-nav-active);
            }
            .app-nav-dropdown-btn i { font-size: 0.8rem; opacity: 0.8; }
            .app-nav-dropdown-btn .chevron {
                font-size: 0.65rem;
                margin-left: 0.1rem;
                transition: transform 0.2s;
            }
            .app-nav-dropdown:hover .chevron { transform: rotate(180deg); }

            .app-nav-dropdown-menu {
                position: absolute;
                top: 100%;
                left: 0;
                padding-top: 10px;
                z-index: 200;
                min-width: 200px;
                opacity: 0;
                visibility: hidden;
                transition: opacity 0.12s ease, visibility 0s linear 0.12s;
                pointer-events: none;
            }
            .app-nav-dropdown-menu-inner {
                background: var(--clr-surface);
                border: 1px solid var(--clr-border);
                border-radius: var(--radius-sm);
                box-shadow: var(--shadow-md);
                padding: 0.35rem;
            }
            .app-nav-dropdown:hover .app-nav-dropdown-menu {
                opacity: 1;
                visibility: visible;
                transition: opacity 0.12s ease, visibility 0s linear 0s;
                pointer-events: all;
            }
            .app-nav-dropdown-item {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.55rem 0.75rem;
                border-radius: var(--radius-sm);
                font-size: 0.85rem;
                font-weight: 500;
                color: var(--clr-text);
                text-decoration: none;
                transition: background 0.15s;
            }
            .app-nav-dropdown-item i { font-size: 0.8rem; color: var(--clr-text-muted); width: 16px; }
            .app-nav-dropdown-item:hover { background: var(--clr-bg); color: var(--clr-primary); }
            .app-nav-dropdown-item:hover i { color: var(--clr-primary); }

            /* User actions (right side) */
            .app-topbar-actions {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                flex-shrink: 0;
            }

            /* Generic top-right dropdown — hover */
            .app-action-dropdown { position: relative; }
            .app-action-dropdown-menu {
                position: absolute;
                top: 100%;
                right: 0;
                z-index: 2000;
                min-width: 260px;
                padding-top: 10px;
                opacity: 0;
                visibility: hidden;
                transition: opacity 0.12s ease, visibility 0s linear 0.12s;
                pointer-events: none;
            }
            .app-action-dropdown:hover .app-action-dropdown-menu {
                opacity: 1;
                visibility: visible;
                transition: opacity 0.12s ease, visibility 0s linear 0s;
                pointer-events: all;
            }
            .app-action-dropdown-menu-inner {
                background: var(--clr-surface);
                border: 1px solid var(--clr-border);
                border-radius: var(--radius);
                box-shadow: 0 8px 30px rgba(0,0,0,0.18);
                overflow: hidden;
            }

            .app-icon-btn {
                position: relative;
                width: 36px;
                height: 36px;
                border-radius: var(--radius-sm);
                background: rgba(255,255,255,0.07);
                border: 1px solid rgba(255,255,255,0.08);
                color: var(--clr-nav-text);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 0.9rem;
                cursor: pointer;
                transition: background 0.15s, color 0.15s;
                text-decoration: none;
            }
            .app-icon-btn:hover,
            .app-action-dropdown:hover .app-icon-btn { background: rgba(255,255,255,0.12); color: white; }
            .app-icon-btn .badge-count {
                position: absolute;
                top: -4px;
                right: -4px;
                background: #EF4444;
                color: white;
                border-radius: 100px;
                min-width: 18px;
                height: 18px;
                font-size: 0.6rem;
                font-weight: 700;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 0 3px;
                border: 1.5px solid var(--clr-nav-bg);
            }

            .app-user-btn {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.35rem 0.75rem 0.35rem 0.4rem;
                background: rgba(255,255,255,0.07);
                border: 1px solid rgba(255,255,255,0.08);
                border-radius: 100px;
                color: var(--clr-nav-text);
                font-size: 0.82rem;
                font-weight: 500;
                cursor: pointer;
                transition: background 0.15s, color 0.15s;
                text-decoration: none;
            }
            .app-user-btn:hover,
            .app-action-dropdown:hover .app-user-btn { background: rgb(252, 0, 0); color: white; }
            .app-user-avatar {
                width: 26px;
                height: 26px;
                border-radius: 50%;
                background: var(--clr-primary);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 0.7rem;
                font-weight: 700;
                color: white;
                flex-shrink: 0;
                overflow: hidden;
            }
            .app-user-avatar img { width: 100%; height: 100%; object-fit: cover; }

            /* Dropdown content styles */
            .dd-header {
                background: linear-gradient(135deg, var(--clr-primary-dark), var(--clr-primary));
                color: white;
                padding: 1.25rem 1rem;
                text-align: center;
            }
            .dd-avatar {
                width: 56px; height: 56px; border-radius: 50%;
                border: 2px solid rgba(255,255,255,0.5);
                background: rgba(255,255,255,0.15);
                display: flex; align-items: center; justify-content: center;
                margin: 0 auto 0.6rem;
                font-size: 1.1rem; font-weight: 700; color: white;
                overflow: hidden;
            }
            .dd-avatar img { width: 100%; height: 100%; object-fit: cover; }
            .dd-name { font-weight: 700; font-size: 0.9rem; }
            .dd-email { font-size: 0.75rem; opacity: 0.8; margin-top: 0.1rem; }
            .dd-stats {
                display: flex;
                border-bottom: 1px solid var(--clr-border);
            }
            .dd-stat {
                flex: 1;
                text-align: center;
                padding: 0.6rem 0.25rem;
                border-right: 1px solid var(--clr-border);
            }
            .dd-stat:last-child { border-right: none; }
            .dd-stat strong { display: block; font-size: 1.1rem; color: var(--clr-primary); font-weight: 700; }
            .dd-stat small { font-size: 0.68rem; color: var(--clr-text-muted); }
            .dd-links { padding: 0.3rem; }
            .dd-link {
                display: flex; align-items: center; gap: 0.6rem;
                padding: 0.6rem 0.75rem;
                border-radius: var(--radius-sm);
                font-size: 0.85rem; font-weight: 500;
                color: var(--clr-text); text-decoration: none;
                transition: background 0.12s;
            }
            .dd-link i { font-size: 0.8rem; color: var(--clr-text-muted); width: 16px; }
            .dd-link:hover { background: var(--clr-bg); color: var(--clr-primary); }
            .dd-link:hover i { color: var(--clr-primary); }
            .dd-link.danger { color: #DC2626; }
            .dd-link.danger i { color: #DC2626; }
            .dd-link.danger:hover { background: #FEF2F2; }
            .dd-sep { height: 1px; background: var(--clr-border); margin: 0.2rem 0; }

            /* Notification dropdown */
            .notif-dd-item {
                display: flex; gap: 0.65rem;
                padding: 0.75rem 1rem;
                border-bottom: 1px solid var(--clr-border);
                align-items: flex-start;
            }
            .notif-dd-item:last-child { border-bottom: none; }
            .notif-dd-item.unread { background: var(--clr-primary-muted); }
            .notif-dd-dot {
                width: 8px; height: 8px; border-radius: 50%;
                background: var(--clr-primary); margin-top: 5px; flex-shrink: 0;
            }

            /* Mobile toggle */
            .app-mobile-toggle {
                display: none;
                background: none;
                border: none;
                color: var(--clr-nav-text);
                font-size: 1.1rem;
                padding: 0.4rem;
                cursor: pointer;
            }

            /* ─── Main content ───────────────────────────────────────── */
            .main-content { flex: 1; padding-bottom: 3rem; }

            /* ─── Flash messages ─────────────────────────────────────── */
            .flash-container {
                padding: 0.75rem 1.5rem 0;
                max-width: 1200px;
                margin: 0 auto;
            }
            .flash-alert {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                padding: 0.85rem 1rem;
                border-radius: var(--radius-sm);
                font-size: 0.875rem;
                font-weight: 500;
                margin-bottom: 0.5rem;
                border: 1px solid;
            }
            .flash-alert i { font-size: 0.9rem; flex-shrink: 0; }
            .flash-success { background: #F0FDF4; color: #166534; border-color: #BBF7D0; }
            .flash-error   { background: #FEF2F2; color: #991B1B; border-color: #FECACA; }
            .flash-warning { background: #FFFBEB; color: #92400E; border-color: #FDE68A; }
            .flash-info    { background: #EFF6FF; color: #1E40AF; border-color: #BFDBFE; }

            /* ─── Bootstrap component overrides ─────────────────────── */
            .btn-primary {
                background-color: var(--clr-primary);
                border-color: var(--clr-primary);
                font-weight: 500;
                border-radius: var(--radius-sm);
            }
            .btn-primary:hover, .btn-primary:focus {
                background-color: var(--clr-primary-dark);
                border-color: var(--clr-primary-dark);
            }
            .btn-outline-primary {
                color: var(--clr-primary);
                border-color: var(--clr-primary);
                font-weight: 500;
                border-radius: var(--radius-sm);
            }
            .btn-outline-primary:hover {
                background-color: var(--clr-primary);
                border-color: var(--clr-primary);
            }
            .btn { border-radius: var(--radius-sm); font-weight: 500; }

            .card {
                border-radius: var(--radius);
                border: 1px solid var(--clr-border);
                box-shadow: var(--shadow-sm);
                margin-bottom: 1.5rem;
                background: var(--clr-surface);
            }
            .card:hover { box-shadow: var(--shadow-md); }
            .card-header {
                background: var(--clr-surface);
                border-bottom: 1px solid var(--clr-border);
                font-weight: 600;
                color: var(--clr-text);
                border-radius: var(--radius) var(--radius) 0 0 !important;
                padding: 1rem 1.25rem;
            }
            .card-body { padding: 1.25rem; }

            .badge.bg-primary { background-color: var(--clr-primary) !important; }
            .badge.bg-success  { background-color: var(--clr-primary) !important; }
            .text-primary { color: var(--clr-primary) !important; }
            .bg-primary   { background-color: var(--clr-primary) !important; }

            .form-control, .form-select {
                border-radius: var(--radius-sm);
                border-color: var(--clr-border);
                font-size: 0.875rem;
                color: var(--clr-text);
            }
            .form-control:focus, .form-select:focus {
                border-color: var(--clr-primary);
                box-shadow: 0 0 0 3px rgba(5,150,105,0.15);
            }
            .form-label { font-weight: 500; font-size: 0.875rem; color: var(--clr-text); }

            .table { color: var(--clr-text); font-size: 0.875rem; }
            .table th { font-weight: 600; color: var(--clr-text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; border-color: var(--clr-border); }
            .table td { border-color: var(--clr-border); vertical-align: middle; }
            .table-hover tbody tr:hover { background-color: var(--clr-primary-muted); }

            /* ─── DSFR component overrides ───────────────────────────── */
            /* Override DSFR colors to match new palette */
            .fr-btn, [class*="fr-btn"] {
                font-family: 'Inter', sans-serif !important;
            }
            .fr-btn:not([class*="fr-btn--secondary"]):not([class*="fr-btn--tertiary"]) {
                background-color: var(--clr-primary) !important;
                color: white !important;
            }
            .fr-alert--info    { --border-color: #BFDBFE; background: #EFF6FF; color: #1E40AF; }
            .fr-alert--success { --border-color: #BBF7D0; background: #F0FDF4; color: #166534; }
            .fr-alert--warning { --border-color: #FDE68A; background: #FFFBEB; color: #92400E; }
            .fr-alert--error   { --border-color: #FECACA; background: #FEF2F2; color: #991B1B; }


            /* ─── Footer ─────────────────────────────────────────────── */
            .app-footer {
                background: var(--clr-nav-bg);
                color: #9CA3AF;
                padding: 2rem 1.5rem;
                margin-top: auto;
                font-size: 0.8125rem;
            }
            .app-footer-inner {
                max-width: 1200px;
                margin: 0 auto;
                display: flex;
                flex-wrap: wrap;
                align-items: center;
                justify-content: space-between;
                gap: 1rem;
            }
            .app-footer-brand { display: flex; align-items: center; gap: 0.6rem; }
            .app-footer-brand-icon {
                width: 28px; height: 28px;
                background: var(--clr-primary);
                border-radius: 6px;
                display: flex; align-items: center; justify-content: center;
                font-size: 0.8rem; color: white;
            }
            .app-footer-brand-name { font-weight: 700; color: #F9FAFB; font-size: 0.9rem; }
            .app-footer-links { display: flex; flex-wrap: wrap; gap: 1.5rem; }
            .app-footer-links a { color: #9CA3AF; text-decoration: none; transition: color 0.15s; }
            .app-footer-links a:hover { color: #F9FAFB; }
            .app-footer-copy { color: #6B7280; font-size: 0.78rem; }

            /* ─── Responsive ─────────────────────────────────────────── */
            @media (max-width: 768px) {
                .app-nav { display: none; }
                .app-mobile-toggle { display: block; }
                .app-brand-tag { display: none; }
                .app-topbar-inner { padding: 0 1rem; }
            }
        </style>
        {% endblock %}
    </head>
    <body>
        {% if app.user %}
        <!-- ─── Topbar ───────────────────────────────────────────────── -->
        <header class="app-topbar">
            <div class="app-topbar-inner">

                <!-- Brand -->
                <a href="{{ path('formation_lister') }}" class="app-brand">
                    <div class="app-brand-icon"><i class="fas fa-graduation-cap"></i></div>
                    <span class="app-brand-name">ABCCI</span>
                    <span class="app-brand-tag">Formation</span>
                </a>

                <!-- Nav -->
                <nav>
                    <ul class="app-nav" id="app-nav-main">
                        <li>
                            <a class="app-nav-link {{ app.request.get('_route') starts with 'formation_' ? 'active' : '' }}"
                               href="{{ path('formation_lister') }}">
                                <i class="fas fa-book-open"></i> Formations
                            </a>
                        </li>
                        <li>
                            <a class="app-nav-link {{ app.request.get('_route') starts with 'messagerie_' ? 'active' : '' }}"
                               href="{{ path('messagerie_index') }}">
                                <i class="fas fa-comment-dots"></i> Messagerie
                            </a>
                        </li>
                        {% if app.user.formations is defined and app.user.formations|length > 0 %}
                        <li>
                            <a class="app-nav-link {{ app.request.get('_route') starts with 'quiz_' and app.request.get('_route') != 'quiz_admin_liste' ? 'active' : '' }}"
                               href="{{ path('quiz_formation_liste', {id: app.user.formations|first.id}) }}">
                                <i class="fas fa-question-circle"></i> Quiz
                            </a>
                        </li>
                        {% endif %}
                        {% if is_granted('ROLE_FORMATEUR') %}
                        <li class="app-nav-dropdown">
                            <button class="app-nav-dropdown-btn">
                                <i class="fas fa-chalkboard-teacher"></i> Formateur
                                <i class="fas fa-chevron-down chevron"></i>
                            </button>
                            <div class="app-nav-dropdown-menu">
                                <div class="app-nav-dropdown-menu-inner">
                                    <a href="{{ path('formateur_mes_formations') }}" class="app-nav-dropdown-item">
                                        <i class="fas fa-layer-group"></i> Mes formations
                                    </a>
                                    <a href="{{ path('quiz_admin_liste') }}" class="app-nav-dropdown-item">
                                        <i class="fas fa-tasks"></i> Gestion des quiz
                                    </a>
                                    <a href="{{ path('profil_inscriptions') }}" class="app-nav-dropdown-item">
                                        <i class="fas fa-user-check"></i> Inscriptions
                                    </a>
                                </div>
                            </div>
                        </li>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                        <li class="app-nav-dropdown">
                            <button class="app-nav-dropdown-btn">
                                <i class="fas fa-shield-alt"></i> Admin
                                <i class="fas fa-chevron-down chevron"></i>
                            </button>
                            <div class="app-nav-dropdown-menu">
                                <div class="app-nav-dropdown-menu-inner">
                                    <a href="{{ path('admin_utilisateur_index') }}" class="app-nav-dropdown-item">
                                        <i class="fas fa-users"></i> Utilisateurs
                                    </a>
                                    <a href="{{ path('formateur_lister') }}" class="app-nav-dropdown-item">
                                        <i class="fas fa-chalkboard-teacher"></i> Formateurs
                                    </a>
                                    <a href="{{ path('notification_creer') }}" class="app-nav-dropdown-item">
                                        <i class="fas fa-bell"></i> Notifications
                                    </a>
                                    <a href="{{ path('quiz_admin_liste') }}" class="app-nav-dropdown-item">
                                        <i class="fas fa-tasks"></i> Quiz
                                    </a>
                                </div>
                            </div>
                        </li>
                        {% endif %}
                    </ul>
                </nav>

                <!-- Actions -->
                <div class="app-topbar-actions">
                    {% set unreadNotifCount = app.user.notifications|length %}

                    <!-- Notifications dropdown -->
                    <div class="app-action-dropdown" id="dd-notif">
                        <button class="app-icon-btn" title="Notifications" type="button">
                            <i class="fas fa-bell"></i>
                            {% if unreadNotifCount > 0 %}
                                <span class="badge-count">{{ unreadNotifCount }}</span>
                            {% endif %}
                        </button>
                        <div class="app-action-dropdown-menu" style="min-width:300px;">
                            <div class="app-action-dropdown-menu-inner">
                                <div style="padding:0.75rem 1rem; border-bottom:1px solid var(--clr-border); font-size:0.8rem; font-weight:700; color:var(--clr-text);">
                                    <i class="fas fa-bell me-1" style="color:var(--clr-primary);"></i> Notifications
                                </div>
                                {% set notifs = app.user.notifications|slice(0, 5) %}
                                {% if notifs|length > 0 %}
                                    {% for notif in notifs %}
                                    <div class="notif-dd-item {{ notif.lu is defined and not notif.lu ? 'unread' : '' }}">
                                        <div class="notif-dd-dot" style="{{ notif.lu is defined and notif.lu ? 'background:var(--clr-border)' : '' }}"></div>
                                        <div>
                                            <div style="font-size:0.82rem; font-weight:600; color:var(--clr-text);">{{ notif.titre }}</div>
                                            <div style="font-size:0.75rem; color:var(--clr-text-muted);">{{ notif.contenu|slice(0,60) }}{% if notif.contenu|length > 60 %}…{% endif %}</div>
                                        </div>
                                    </div>
                                    {% endfor %}
                                {% else %}
                                    <div style="padding:1.5rem; text-align:center; color:var(--clr-text-muted); font-size:0.85rem;">
                                        <i class="fas fa-bell-slash" style="display:block; font-size:1.5rem; opacity:0.3; margin-bottom:0.5rem;"></i>
                                        Aucune notification
                                    </div>
                                {% endif %}
                                <div style="padding:0.5rem; border-top:1px solid var(--clr-border);">
                                    <a href="{{ path('notification_liste') }}" style="display:block; text-align:center; font-size:0.8rem; color:var(--clr-primary); font-weight:600; padding:0.4rem;">
                                        Voir toutes →
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Messagerie -->
                    <a href="{{ path('messagerie_index') }}" class="app-icon-btn" title="Messagerie">
                        <i class="fas fa-comment-dots"></i>
                    </a>

                    <!-- Compte dropdown -->
                    <div class="app-action-dropdown" id="dd-user">
                        <button class="app-user-btn" type="button" style="border:none; background:rgba(255,255,255,0.07);">
                            <div class="app-user-avatar">
                                {% if app.user.photo %}
                                    <img src="{{ asset('uploads/photos/' ~ app.user.photo) }}" alt="Photo">
                                {% else %}
                                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                                {% endif %}
                            </div>
                            <span>{{ app.user.prenom }}</span>
                            <i class="fas fa-chevron-down" style="font-size:0.6rem; opacity:0.6;"></i>
                        </button>
                        <div class="app-action-dropdown-menu" style="min-width:280px;">
                            <div class="app-action-dropdown-menu-inner">
                                <div class="dd-header">
                                    <div class="dd-avatar">
                                        {% if app.user.photo %}
                                            <img src="{{ asset('uploads/photos/' ~ app.user.photo) }}" alt="Photo">
                                        {% else %}
                                            {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                                        {% endif %}
                                    </div>
                                    <div class="dd-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
                                    <div class="dd-email">{{ app.user.email }}</div>
                                </div>
                                <div class="dd-stats">
                                    <div class="dd-stat">
                                        <strong>{{ app.user.inscriptions|length }}</strong>
                                        <small>Formations</small>
                                    </div>
                                    <div class="dd-stat">
                                        <strong>{{ app.user.points ?? 0 }}</strong>
                                        <small>Points</small>
                                    </div>
                                    <div class="dd-stat">
                                        <strong>{{ app.user.niveau ?? '—' }}</strong>
                                        <small>Niveau</small>
                                    </div>
                                </div>
                                <div class="dd-links">
                                    <a href="{{ path('profil_index') }}" class="dd-link">
                                        <i class="fas fa-user"></i> Mon profil
                                    </a>
                                    <a href="{{ path('profil_badges') }}" class="dd-link">
                                        <i class="fas fa-award"></i> Mes badges
                                    </a>
                                    <a href="{{ path('profil_planning') }}" class="dd-link">
                                        <i class="fas fa-calendar-alt"></i> Mon planning
                                    </a>
                                    <a href="{{ path('profil_modifier') }}" class="dd-link">
                                        <i class="fas fa-edit"></i> Modifier mon profil
                                    </a>
                                    <div class="dd-sep"></div>
                                    <a href="{{ path('app_logout') }}" class="dd-link danger">
                                        <i class="fas fa-sign-out-alt"></i> Déconnexion
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button class="app-mobile-toggle" onclick="toggleMobileNav()">
                        <i class="fas fa-bars"></i>
                    </button>
                </div>
            </div>
        </header>

        {% endif %}

        <!-- ─── Flash messages ──────────────────────────────────────── -->
        {% if app.flashes|length > 0 %}
        <div class="flash-container">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    {% set cls = label == 'success' ? 'flash-success' : (label == 'danger' or label == 'error' ? 'flash-error' : (label == 'warning' ? 'flash-warning' : 'flash-info')) %}
                    {% set icon = label == 'success' ? 'fa-check-circle' : (label == 'danger' or label == 'error' ? 'fa-times-circle' : (label == 'warning' ? 'fa-exclamation-triangle' : 'fa-info-circle')) %}
                    <div class="flash-alert {{ cls }}" role="alert">
                        <i class="fas {{ icon }}"></i>
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
        {% endif %}

        <!-- ─── Body ────────────────────────────────────────────────── -->
        <main class="main-content">
            {% block body %}{% endblock %}
        </main>

        <!-- ─── Footer ──────────────────────────────────────────────── -->
        {% if app.user %}
        <footer class="app-footer">
            <div class="app-footer-inner">
                <div class="app-footer-brand">
                    <div class="app-footer-brand-icon"><i class="fas fa-graduation-cap"></i></div>
                    <span class="app-footer-brand-name">ABCCI Formation</span>
                </div>
                <div class="app-footer-links">
                    <a href="{{ path('formation_lister') }}">Formations</a>
                    <a href="{{ path('messagerie_index') }}">Messagerie</a>
                    <a href="#">Mentions légales</a>
                    <a href="mailto:anne@abcci.fr">anne@abcci.fr</a>
                    <a href="tel:+33231935300">02.31.93.53.00</a>
                </div>
                <div class="app-footer-copy">© {{ "now"|date("Y") }} ABCCI — Tous droits réservés</div>
            </div>
        </footer>
        {% endif %}

        <!-- Scripts -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script>
            function toggleMobileNav() {
                var nav = document.getElementById('app-nav-main');
                if (!nav) return;
                if (nav.style.display === 'flex') {
                    nav.style.display = 'none';
                } else {
                    nav.style.display = 'flex';
                    nav.style.flexDirection = 'column';
                    nav.style.position = 'absolute';
                    nav.style.top = '60px';
                    nav.style.left = '0';
                    nav.style.right = '0';
                    nav.style.background = '#111827';
                    nav.style.padding = '0.5rem';
                    nav.style.zIndex = '999';
                    nav.style.borderBottom = '1px solid rgba(255,255,255,0.08)';
                }
            }
        </script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
