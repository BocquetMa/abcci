                    <h6>{{ app.user.inscriptions|length }}</h6>
                    <small>Formations</small>
                </div>
                <div class="col border-start">
                    <h6>{% if app.user.badges is defined %}{{ app.user.badges|length }}{% else %}0{% endif %}</h6>
                    <small>Badges</small>
                </div>
                <div class="col border-start">
                    <h6>{% if app.user.niveau is defined %}{{ app.user.niveau }}{% else %}1{% endif %}</h6>
                    <small>Niveau</small>
                </div>
            </div>
        </div>

        <div class="list-group list-group-flush">
