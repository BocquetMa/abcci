            </a>
            <a href="{{ path('profil_badges') }}" class="list-group-item list-group-item-action">
                <i class="fas fa-award me-2"></i> Mes badges 
                {% if app.user.badges is defined and app.user.badges|length > 0 %}
                    <span class="badge bg-primary float-end">{{ app.user.badges|length }}</span>
                {% endif %}
            </a>
            <a href="{{ path('profil_planning') }}" class="list-group-item list-group-item-action">
                <i class="fas fa-calendar-alt me-2"></i> Mon planning
            </a>
        </div>

        <div class="user-info border-top">
            <div class="mb-2">
                <i class="fas fa-phone-alt me-2"></i>
                {{ app.user.telephone ?? 'Non renseigné' }}
            </div>
            {% if is_granted('ROLE_FORMATEUR') and app.user.biographie %}
