                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle {{ app.request.get('_route') starts with 'admin_' or app.request.get('_route') starts with 'notification_' ? 'active' : '' }}" href="#" role="button" data-bs-toggle="dropdown">
