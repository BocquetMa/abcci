                </a>
                <a href="{{ path('app_logout') }}" class="btn btn-danger">
                    <i class="fas fa-sign-out-alt me-2"></i>Déconnexion
                </a>
            </div>
        </div>
    </div>
</li>
                        </ul>
                    </div>
                </div>
            </nav>

            <!-- Modal Notifications -->
            <div class="modal fade" id="notificationsModal" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">
                                <i class="fas fa-bell me-2"></i>Notifications
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body p-0">
                            {% if app.user %}
                                {% set notifications = app.user.notifications|slice(0, 5) %}
                                <div class="list-group">
                                    {% if notifications|length > 0 %}
                                        {% for notification in notifications %}
                                            <a href="#" class="list-group-item list-group-item-action {{ notification.lu ? '' : 'bg-light' }}">
                                                <div class="d-flex w-100 justify-content-between">
                                                    <h6 class="mb-1">{{ notification.titre }}</h6>
                                                    <small class="text-muted">{{ notification.dateCreation|date("d/m/Y H:i") }}</small>
                                                </div>
                                                <p class="mb-1">{{ notification.contenu|slice(0, 100) }}{% if notification.contenu|length > 100 %}...{% endif %}</p>
                                                <small class="notification-time">
                                                    <i class="fas fa-info-circle me-1"></i>
                                                    {% if notification.type is defined %}
                                                        {{ notification.type }}
                                                    {% else %}
                                                        Information
                                                    {% endif %}
                                                </small>
                                            </a>
                                        {% endfor %}
                                    {% else %}
                                        <div class="list-group-item text-center py-4">
                                            <i class="fas fa-bell-slash fa-2x mb-3 text-muted"></i>
                                            <p>Vous n'avez pas de notifications</p>
                                        </div>
                                    {% endif %}
                                    
                                    <a href="{{ path('notification_liste') }}" class="list-group-item text-center">
                                        <i class="fas fa-list me-1"></i>
                                        Voir toutes les notifications
                                    </a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}

        <div class="main-content">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} alert-dismissible fade show animate__animated animate__fadeIn m-3" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </div>

        {% if app.user %}
