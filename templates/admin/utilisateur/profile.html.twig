{# templates/admin/utilisateur/profile.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .profile-header {
            background: linear-gradient(135deg, #6B73FF 0%, #000DFF 100%);
            padding: 2rem 0;
            margin-bottom: 2rem;
            color: white;
        }
        .profile-picture {
            width: 150px;
            height: 150px;
            object-fit: cover;
            border: 4px solid white;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .badge-custom {
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-size: 0.9rem;
            margin: 0.25rem;
        }
        .stats-card {
            border-radius: 15px;
            transition: transform 0.3s;
        }
        .stats-card:hover {
            transform: translateY(-5px);
        }
        .social-icons i {
            font-size: 1.5rem;
            margin: 0 0.5rem;
        }
        .achievement-badge {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0.5rem;
            background: #f8f9fa;
            border: 2px solid #dee2e6;
        }
        .achievement-badge i {
            font-size: 2rem;
        }
    </style>
{% endblock %}

{% block body %}
<div class="profile-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-3 text-center">
                {% if user.photo %}
                    <img src="{{ asset('uploads/photos/' ~ user.photo) }}" 
                         alt="Photo de profil" 
                         class="profile-picture rounded-circle">
                {% else %}
                    <div class="profile-picture rounded-circle bg-secondary d-flex align-items-center justify-content-center">
                        <i class="fas fa-user fa-4x text-white"></i>
                    </div>
                {% endif %}
            </div>
            <div class="col-md-9">
                <h1>{{ user.prenom }} {{ user.nom }}</h1>
                <p class="lead">{{ user.email }}</p>
                <div class="mt-3">
                    {% for role in user.roles %}
                        {% if role != 'ROLE_USER' %}
                            <span class="badge badge-custom bg-light text-dark">
                                {{ role|replace({'ROLE_': ''}) }}
                            </span>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h3>Informations du profil</h3>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="row">
                            <div class="col-md-6">
                                {{ form_row(form.photoFile) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.cvFile) }}
                            </div>
                        </div>

                        {{ form_row(form.biographieDetaillee) }}

                        <h4 class="mt-4">Liens sociaux</h4>
                        <div class="social-links" 
                             data-prototype="{{ form_widget(form.socialLinks.vars.prototype)|e('html_attr') }}">
                            {% for socialLink in form.socialLinks %}
                                <div class="social-link-item mb-3">
                                    {{ form_row(socialLink) }}
                                </div>
                            {% endfor %}
                            <button type="button" class="btn btn-outline-primary add-social-link">
                                <i class="fas fa-plus"></i> Ajouter un lien
                            </button>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Enregistrer les modifications
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h3>Certifications</h3>
                </div>
                <div class="card-body">
                    {% if user.certifications is not empty %}
                        <div class="row">
                            {% for certification in user.certifications %}
                                <div class="col-md-6 mb-3">
                                    <div class="card h-100">
                                        <div class="card-body">
                                            <h5>{{ certification.titre }}</h5>
                                            <p class="text-muted">
                                                Obtenue le {{ certification.dateObtention|date('d/m/Y') }}
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-muted">Aucune certification pour le moment.</p>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card stats-card mb-4">
                <div class="card-header">
                    <h3>Statistiques</h3>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span>Niveau</span>
                        <span class="badge bg-primary">{{ user.niveau }}</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span>Points</span>
                        <span class="badge bg-success">{{ user.points }}</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span>Formations complétées</span>
                        <span class="badge bg-info">{{ stats.formations_completees }}</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span>Certifications</span>
                        <span class="badge bg-warning">{{ stats.certifications }}</span>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <h3>Badges</h3>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap justify-content-center">
                        {% for badge in user.badges %}
                            <div class="achievement-badge" title="{{ badge }}">
                                <i class="fas fa-award text-primary"></i>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            {% if user.cvFilename %}
                <div class="card mb-4">
                    <div class="card-header">
                        <h3>CV</h3>
                    </div>
                    <div class="card-body text-center">
                        <a href="{{ asset('uploads/cv/' ~ user.cvFilename) }}" 
                           class="btn btn-outline-primary" 
                           target="_blank">
                            <i class="fas fa-file-pdf me-2"></i>Voir le CV
                        </a>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Gestion des liens sociaux dynamiques
        document.addEventListener('DOMContentLoaded', function() {
            const addButton = document.querySelector('.add-social-link');
            const container = document.querySelector('.social-links');
            let index = container.querySelectorAll('.social-link-item').length;

            addButton.addEventListener('click', function() {
                const prototype = container.dataset.prototype;
                const newForm = prototype.replace(/__name__/g, index);
                const div = document.createElement('div');
                div.classList.add('social-link-item', 'mb-3');
                div.innerHTML = newForm;
                container.insertBefore(div, addButton);
                index++;
            });
        });
    </script>
{% endblock %}
