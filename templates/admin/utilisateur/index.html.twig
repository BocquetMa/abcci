{# templates/admin/utilisateur/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Gestion des Utilisateurs{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .user-management {
            padding: 2rem 0;
        }
        .user-management__header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }
        .user-management__title {
            color: #333;
            font-weight: 600;
            margin: 0;
        }
        .user-table {
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        .user-table thead {
            background-color: #f8f9fa;
        }
        .user-table th {
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            padding: 1rem;
            border-bottom: 2px solid #dee2e6;
        }
        .user-table td {
            padding: 1rem;
            vertical-align: middle;
        }
        .user-table tbody tr:hover {
            background-color: rgba(0, 123, 255, 0.05);
        }
        .user-table tbody tr:not(:last-child) {
            border-bottom: 1px solid #e9ecef;
        }
        .badge-role {
            display: inline-block;
            padding: 0.35rem 0.5rem;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            background-color: #e9ecef;
            color: #495057;
        }
        .badge-role.admin {
            background-color: #dc3545;
            color: white;
        }
        .badge-role.user {
            background-color: #17a2b8;
            color: white;
        }
        .action-buttons {
            display: flex;
            gap: 0.5rem;
        }
        .btn-add {
            background-color: #28a745;
            border-color: #28a745;
            padding: 0.5rem 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .btn-edit {
            background-color: #007bff;
            border-color: #007bff;
            padding: 0.375rem 0.75rem;
        }
        .btn-delete {
            background-color: #dc3545;
            border-color: #dc3545;
            padding: 0.375rem 0.75rem;
        }
        .empty-state {
            text-align: center;
            padding: 3rem;
            background-color: #f8f9fa;
            border-radius: 8px;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container user-management">
    <div class="user-management__header">
        <h1 class="user-management__title">Gestion des Utilisateurs</h1>
        <a href="{{ path('admin_utilisateur_ajouter') }}" class="btn btn-success btn-add">
            <i class="fas fa-plus-circle"></i> Ajouter un utilisateur
        </a>
    </div>
    
    {% if utilisateurs|length > 0 %}
        <div class="table-responsive">
            <table class="table user-table">
                <thead>
                    <tr>
                        <th width="5%">ID</th>
                        <th width="20%">Nom</th>
                        <th width="20%">Prénom</th>
                        <th width="25%">Email</th>
                        <th width="15%">Rôle</th>
                        <th width="15%">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for utilisateur in utilisateurs %}
                        <tr>
                            <td>{{ utilisateur.id }}</td>
                            <td>{{ utilisateur.nom }}</td>
                            <td>{{ utilisateur.prenom }}</td>
                            <td>
                                <a href="mailto:{{ utilisateur.email }}">{{ utilisateur.email }}</a>
                            </td>
                            <td>
                                {% for role in utilisateur.roles %}
                                    <span class="badge-role {% if role == 'ROLE_ADMIN' %}admin{% elseif role == 'ROLE_USER' %}user{% endif %}">
                                        {{ role|replace({'ROLE_': ''}) }}
                                    </span>
                                {% endfor %}
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a href="{{ path('admin_utilisateur_modifier', {id: utilisateur.id}) }}" class="btn btn-primary btn-edit" title="Modifier">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="{{ path('admin_utilisateur_supprimer', {id: utilisateur.id}) }}" 
                                       class="btn btn-danger btn-delete" 
                                       title="Supprimer"
                                       onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="empty-state">
            <h3>Aucun utilisateur trouvé</h3>
            <p>Commencez par ajouter un nouvel utilisateur en cliquant sur le bouton ci-dessus.</p>
        </div>
    {% endif %}
</div>
{% endblock %}