{# templates/admin/utilisateur/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Gestion des utilisateurs - ABCCI{% endblock %}

{% block body %}
<div class="fr-container fr-mt-4w fr-mb-6w">
    <div class="d-flex justify-content-between align-items-center fr-mb-3w flex-wrap gap-2">
        <h1 class="fr-h2 mb-0">Gestion des utilisateurs</h1>
        <a href="{{ path('admin_utilisateur_ajouter') }}" class="fr-btn fr-icon-user-add-line fr-btn--icon-left">
            Ajouter un utilisateur
        </a>
    </div>

    {% if utilisateurs|length > 0 %}
        <div class="fr-table fr-table--bordered fr-table--no-caption">
            <table>
                <thead>
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">Nom</th>
                        <th scope="col">Prénom</th>
                        <th scope="col">Email</th>
                        <th scope="col">Rôle(s)</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for utilisateur in utilisateurs %}
                        <tr>
                            <td>{{ utilisateur.id }}</td>
                            <td>{{ utilisateur.nom }}</td>
                            <td>{{ utilisateur.prenom }}</td>
                            <td>
                                <a href="mailto:{{ utilisateur.email }}">{{ utilisateur.email }}</a>
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    {% for role in utilisateur.roles %}
                                        {% set roleLabel = role|replace({'ROLE_': ''}) %}
                                        <span class="fr-badge fr-badge--sm
                                            {% if role == 'ROLE_ADMIN' %}fr-badge--error
                                            {% elseif role == 'ROLE_FORMATEUR' %}fr-badge--purple-glycine
                                            {% else %}fr-badge--blue-cumulus{% endif %}">
                                            {{ roleLabel }}
                                        </span>
                                    {% endfor %}
                                </div>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="{{ path('admin_utilisateur_modifier', {id: utilisateur.id}) }}"
                                       class="fr-btn fr-btn--sm fr-btn--secondary fr-icon-edit-line"
                                       title="Modifier {{ utilisateur.prenom }} {{ utilisateur.nom }}"></a>
                                    <a href="{{ path('admin_utilisateur_supprimer', {id: utilisateur.id}) }}"
                                       class="fr-btn fr-btn--sm fr-btn--tertiary fr-icon-delete-line"
                                       title="Supprimer {{ utilisateur.prenom }} {{ utilisateur.nom }}"
                                       onclick="return confirm('Supprimer l\'utilisateur {{ utilisateur.prenom }} {{ utilisateur.nom }} ?')"></a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="fr-alert fr-alert--info" role="alert">
            <p class="fr-alert__title">Aucun utilisateur</p>
            <p>Commencez par ajouter un premier utilisateur.</p>
        </div>
    {% endif %}
</div>
{% endblock %}
