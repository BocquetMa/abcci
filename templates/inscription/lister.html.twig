{% extends 'base.html.twig' %}

{% block title %}Liste des Inscriptions{% endblock %}

{% block body %}
<div class="container mx-auto mt-10">
    <h1 class="text-2xl font-bold mb-6">Liste des Inscriptions</h1>

    <div class="flex justify-end mb-4">
        <a href="{{ path('inscription_ajouter') }}" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">
            Nouvelle Inscription
        </a>
    </div>

    {% if inscriptions is not empty %}
        <table class="w-full border-collapse">
            <thead>
                <tr class="bg-gray-200">
                    <th class="border p-2">ID</th>
                    <th class="border p-2">Formation</th>
                    <th class="border p-2">Utilisateur</th>
                    <th class="border p-2">Date</th>
                    <th class="border p-2">Places</th>
                    <th class="border p-2">Statut</th>
                    <th class="border p-2">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for inscription in inscriptions %}
                    <tr class="{{ not inscription.estValide ? 'bg-yellow-100' : 'bg-white' }}">
                        <td class="border p-2">{{ inscription.id }}</td>
                        <td class="border p-2">
                            {% for formation in inscription.formations %}
                                <div class="mb-1">{{ formation.titre }}</div>
                            {% endfor %}
                        </td>
                        <td class="border p-2">{{ inscription.utilisateur.nom }}</td>
                        <td class="border p-2">{{ inscription.dateInscription|date('d/m/Y H:i') }}</td>
                        <td class="border p-2">{{ inscription.nombrePlaces }}</td>
                        <td class="border p-2">
                            {% if inscription.estValide %}
                                <span class="text-green-600">Validée</span>
                            {% else %}
                                <span class="text-yellow-600">En attente</span>
                            {% endif %}
                        </td>
                        <td class="border p-2">
                            <div class="flex space-x-2">
                                <a href="{{ path('inscription_voir', {'id': inscription.id}) }}" class="text-blue-500 hover:text-blue-700">
                                    Voir
                                </a>
                                <a href="{{ path('inscription_modifier', {'id': inscription.id}) }}" class="text-green-500 hover:text-green-700">
                                    Modifier
                                </a>
                                <form action="{{ path('inscription_supprimer', {'id': inscription.id}) }}" method="POST" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette inscription ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('supprimer' ~ inscription.id) }}">
                                    <button type="submit" class="text-red-500 hover:text-red-700">
                                        Supprimer
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="text-center text-gray-600">Aucune inscription trouvée.</p>
    {% endif %}
</div>
{% endblock %}