{% extends 'base.html.twig' %}

{% block title %}Modification de l'Inscription{% endblock %}

{% block body %}
<div class="container mx-auto mt-10">
    <h1 class="text-2xl font-bold mb-6">Modifier l'Inscription</h1>

    {{ form_start(form, {'attr': {'class': 'max-w-lg mx-auto'}}) }}
        <div class="mb-4">
            {{ form_label(form.formation, 'Formation', {'label_attr': {'class': 'block text-gray-700 text-sm font-bold mb-2'}}) }}
            {{ form_widget(form.formation, {'attr': {'class': 'shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline'}}) }}
            {{ form_errors(form.formation) }}
        </div>

        <div class="mb-4">
            {{ form_label(form.utilisateur, 'Utilisateur', {'label_attr': {'class': 'block text-gray-700 text-sm font-bold mb-2'}}) }}
            {{ form_widget(form.utilisateur, {'attr': {'class': 'shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline'}}) }}
            {{ form_errors(form.utilisateur) }}
        </div>

        <div class="mb-4">
            {{ form_label(form.nombrePlaces, 'Nombre de places', {'label_attr': {'class': 'block text-gray-700 text-sm font-bold mb-2'}}) }}
            {{ form_widget(form.nombrePlaces, {'attr': {'class': 'shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline'}}) }}
            {{ form_errors(form.nombrePlaces) }}
        </div>

        <div class="mb-4">
            {{ form_label(form.estValide, 'Validation de l\'inscription', {'label_attr': {'class': 'block text-gray-700 text-sm font-bold mb-2'}}) }}
            {{ form_widget(form.estValide, {'attr': {'class': 'mr-2 leading-tight'}}) }}
            {{ form_errors(form.estValide) }}
        </div>

        {{ form_rest(form) }}

        <div class="flex items-center justify-between">
            <button type="submit" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline">
                Mettre à jour
            </button>
            <a href="{{ path('inscription_lister') }}" class="inline-block align-baseline font-bold text-sm text-blue-500 hover:text-blue-800">
                Annuler
            </a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}