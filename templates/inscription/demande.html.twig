{# templates/inscription/demande.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Inscription à la formation - {{ formation.titre }}{% endblock %}

{% block body %}
<div class="container my-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header">
                    <h2 class="mb-0">Demande d'inscription</h2>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <h4>{{ formation.titre }}</h4>
                        <p class="text-muted">{{ formation.description }}</p>
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="fas fa-calendar me-2 text-primary"></i>
                                    <span>{{ formation.dateDebut|date('d/m/Y') }} - {{ formation.dateFin|date('d/m/Y') }}</span>
                                </div>
                                <div class="d-flex align-items-center mb-2">
                                    <i class="fas fa-clock me-2 text-primary"></i>
                                    <span>Durée: {{ formation.duree }} heures</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex align-items-center mb-2">
                                    <i class="fas fa-user-tie me-2 text-primary"></i>
                                    <span>Formateur: {{ formation.formateur.prenom }} {{ formation.formateur.nom }}</span>
                                </div>
                                <div class="d-flex align-items-center mb-2">
                                    <i class="fas fa-users me-2 text-primary"></i>
                                    <span>Places: {{ formation.placesDisponibles }} disponibles sur {{ formation.nombrePlaces }}</span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="alert alert-info">
                            <p class="mb-0">
                                <i class="fas fa-info-circle me-2"></i>
                                Votre demande sera examinée par le formateur ou l'administrateur. Vous recevrez une notification lorsqu'elle sera traitée.
                            </p>
                        </div>
                    </div>
                    
                    {{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}
                        {{ form_row(form.motif) }}
                        
                        <div class="d-flex justify-content-between mt-4">
                            <a href="{{ path('formation_voir', {id: formation.id}) }}" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Retour
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane me-2"></i>Soumettre ma demande
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}