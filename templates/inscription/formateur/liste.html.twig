{# templates/inscription/formateur/liste.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Gestion des inscriptions - {{ parent() }}{% endblock %}

{% block body %}
<div class="container my-4">
    <div class="row">
        <div class="col-md-3">
            {% include 'formateur/_sidebar.html.twig' with {active: 'inscriptions'} %}
        </div>
        <div class="col-md-9">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h2 class="mb-0">Gestion des inscriptions</h2>
                    <div>
                        <a href="{{ path('inscription_formateur_en_attente') }}" class="btn btn-warning btn-sm me-2">
                            <i class="fas fa-user-clock me-1"></i>En attente
                            {% if inscriptions|filter(i => i.statut == 'en_attente')|length > 0 %}
                                <span class="badge bg-light text-dark ms-1">{{ inscriptions|filter(i => i.statut == 'en_attente')|length }}</span>
                            {% endif %}
                        </a>
                        <button type="button" class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#filterModal">
                            <i class="fas fa-filter me-1"></i>Filtrer
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <ul class="nav nav-tabs mb-4" id="inscriptionTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="all-tab" data-bs-toggle="tab" data-bs-target="#all" type="button" role="tab" aria-controls="all" aria-selected="true">
                                Toutes
                                <span class="badge bg-secondary ms-1">{{ inscriptions|length }}</span>
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending" type="button" role="tab" aria-controls="pending" aria-selected="false">
                                En attente
                                <span class="badge bg-warning ms-1">{{ inscriptions|filter(i => i.statut == 'en_attente')|length }}</span>
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="accepted-tab" data-bs-toggle="tab" data-bs-target="#accepted" type="button" role="tab" aria-controls="accepted" aria-selected="false">
                                Acceptées
                                <span class="badge bg-success ms-1">{{ inscriptions|filter(i => i.statut == 'acceptee')|length }}</span>
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="rejected-tab" data-bs-toggle="tab" data-bs-target="#rejected" type="button" role="tab" aria-controls="rejected" aria-selected="false">
                                Refusées
                                <span class="badge bg-danger ms-1">{{ inscriptions|filter(i => i.statut == 'refusee')|length }}</span>
                            </button>
                        </li>
                    </ul>
                    
                    <div class="tab-content" id="inscriptionTabsContent">
                        <div class="tab-pane fade show active" id="all" role="tabpanel" aria-labelledby="all-tab">
                            {% if inscriptions|length > 0 %}
                                <div class="table-responsive">
                                    <table class="table table-hover">
                                        <thead>
                                            <tr>
                                                <th>Formation</th>
                                                <th>Participant</th>
                                                <th>Date de demande</th>
                                                <th>Statut</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for inscription in inscriptions %}
                                                <tr>
                                                    <td>
                                                        <a href="{{ path('formation_voir', {id: inscription.formation.id}) }}" class="text-decoration-none">
                                                            {{ inscription.formation.titre }}
                                                        </a>
                                                    </td>
                                                    <td>{{ inscription.utilisateur.prenom }} {{ inscription.utilisateur.nom }}</td>
                                                    <td>{{ inscription.dateInscription|date('d/m/Y') }}</td>
                                                    <td>
                                                        {% if inscription.statut == 'en_attente' %}
                                                            <span class="badge bg-warning">En attente</span>
                                                        {% elseif inscription.statut == 'acceptee' %}
                                                            <span class="badge bg-success">Acceptée</span>
                                                        {% elseif inscription.statut == 'refusee' %}
                                                            <span class="badge bg-danger">Refusée</span>
                                                        {% endif %}
                                                    </td>
                                                    <td>
                                                        <div class="btn-group" role="group">
                                                            {% if inscription.statut == 'en_attente' %}
                                                                <a href="{{ path('inscription_valider', {id: inscription.id}) }}" class="btn btn-sm btn-primary">
                                                                    <i class="fas fa-check me-1"></i>Traiter
                                                                </a>
                                                            {% elseif inscription.statut == 'acceptee' and not inscription.estTerminee %}
                                                                <a href="{{ path('inscription_terminer', {id: inscription.id}) }}" class="btn btn-sm btn-success" onclick="return confirm('Êtes-vous sûr de vouloir marquer cette formation comme terminée ?')">
                                                                    <i class="fas fa-check-circle me-1"></i>Terminer
                                                                </a>
                                                            {% endif %}
                                                            <a href="{{ path('inscription_details', {id: inscription.id}) }}" class="btn btn-sm btn-outline-info">
                                                                <i class="fas fa-info-circle"></i>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            {% else %}
                                <div class="alert alert-info">
                                    <p class="mb-0">Aucune inscription trouvée.</p>
                                </div>
                            {% endif %}
                        </div>
                        
                        <div class="tab-pane fade" id="pending" role="tabpanel" aria-labelledby="pending-tab">
                            {% set pendingInscriptions = inscriptions|filter(i => i.statut == 'en_attente') %}
                            {% if pendingInscriptions|length > 0 %}
                                <div class="table-responsive">
                                    <table class="table table-hover">
                                        <thead>
                                            <tr>
                                                <th>Formation</th>
                                                <th>Participant</th>
                                                <th>Date de demande</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for inscription in pendingInscriptions %}
                                                <tr>
                                                    <td>
                                                        <a href="{{ path('formation_voir', {id: inscription.formation.id}) }}" class="text-decoration-none">
                                                            {{ inscription.formation.titre }}
                                                        </a>
                                                    </td>
                                                    <td>{{ inscription.utilisateur.prenom }} {{ inscription.utilisateur.nom }}</td>
                                                    <td>{{ inscription.dateInscription|date('d/m/Y') }}</td>
                                                    <td>
                                                        <div class="btn-group" role="group">
                                                            <a href="{{ path('inscription_valider', {id: inscription.id}) }}" class="btn btn-sm btn-primary">
                                                                <i class="fas fa-check me-1"></i>Traiter
                                                            </a>
                                                            <a href="{{ path('inscription_details', {id: inscription.id}) }}" class="btn btn-sm btn-outline-info">
                                                                <i class="fas fa-info-circle"></i>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            {% else %}
                                <div class="alert alert-info">
                                    <p class="mb-0">Aucune inscription en attente.</p>
                                </div>
                            {% endif %}
                        </div>
                        
                        <div class="tab-pane fade" id="accepted" role="tabpanel" aria-labelledby="accepted-tab">
                            {% set acceptedInscriptions = inscriptions|filter(i => i.statut == 'acceptee') %}
                            {% if acceptedInscriptions|length > 0 %}
                                <div class="table-responsive">
                                    <table class="table table-hover">
                                        <thead>
                                            <tr>
                                                <th>Formation</th>
                                                <th>Participant</th>
                                                <th>Date de début</th>
                                                <th>Terminée</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for inscription in acceptedInscriptions %}
                                                <tr>
                                                    <td>
                                                        <a href="{{ path('formation_voir', {id: inscription.formation.id}) }}" class="text-decoration-none">
                                                            {{ inscription.formation.titre }}
                                                        </a>
                                                    </td>
                                                    <td>{{ inscription.utilisateur.prenom }} {{ inscription.utilisateur.nom }}</td>
                                                    <td>{{ inscription.dateDebut|date('d/m/Y') }}</td>
                                                    <td>
                                                        {% if inscription.estTerminee %}
                                                            <span class="badge bg-info">Oui</span>
                                                        {% else %}
                                                            <span class="badge bg-secondary">Non</span>
                                                        {% endif %}
                                                    </td>
                                                    <td>
                                                        <div class="btn-group" role="group">
                                                            {% if not inscription.estTerminee %}
                                                                <a href="{{ path('inscription_terminer', {id: inscription.id}) }}" class="btn btn-sm btn-success" onclick="return confirm('Êtes-vous sûr de vouloir marquer cette formation comme terminée ?')">
                                                                    <i class="fas fa-check-circle me-1"></i>Terminer
                                                                </a>
                                                            {% endif %}
                                                            <a href="{{ path('inscription_details', {id: inscription.id}) }}" class="btn btn-sm btn-outline-info">
                                                                <i class="fas fa-info-circle"></i>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            {% else %}
                                <div class="alert alert-info">
                                    <p class="mb-0">Aucune inscription acceptée.</p>
                                </div>
                            {% endif %}
                        </div>
                        
                        <div class="tab-pane fade" id="rejected" role="tabpanel" aria-labelledby="rejected-tab">
                            {% set rejectedInscriptions = inscriptions|filter(i => i.statut == 'refusee') %}
                            {% if rejectedInscriptions|length > 0 %}
                                <div class="table-responsive">
                                    <table class="table table-hover">
                                        <thead>
                                            <tr>
                                                <th>Formation</th>
                                                <th>Participant</th>
                                                <th>Date de refus</th>
                                                <th>Motif</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for inscription in rejectedInscriptions %}
                                                <tr>
                                                    <td>
                                                        <a href="{{ path('formation_voir', {id: inscription.formation.id}) }}" class="text-decoration-none">
                                                            {{ inscription.formation.titre }}
                                                        </a>
                                                    </td>
                                                    <td>{{ inscription.utilisateur.prenom }} {{ inscription.utilisateur.nom }}</td>
                                                    <td>{{ inscription.dateConfirmation|date('d/m/Y') }}</td>
                                                    <td>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="tooltip" data-bs-placement="top" title="{{ inscription.motif }}">
                                                            <i class="fas fa-eye me-1"></i>Voir
                                                        </button>
                                                    </td>
                                                    <td>
                                                        <a href="{{ path('inscription_details', {id: inscription.id}) }}" class="btn btn-sm btn-outline-info">
                                                            <i class="fas fa-info-circle"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            {% else %}
                                <div class="alert alert-info">
                                    <p class="mb-0">Aucune inscription refusée.</p>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal de filtrage -->
<div class="modal fade" id="filterModal" tabindex="-1" aria-labelledby="filterModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="filterModalLabel">Filtrer les inscriptions</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form method="get" action="{{ path('inscription_formateur_liste') }}" id="filter-form">
                    <div class="mb-3">
                        <label for="formation" class="form-label">Formation</label>
                        <select name="formation" id="formation" class="form-select">
                            <option value="">Toutes les formations</option>
                            {% for formation in app.user.formations %}
                                <option value="{{ formation.id }}">{{ formation.titre }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label for="statut" class="form-label">Statut</label>
                        <select name="statut" id="statut" class="form-select">
                            <option value="">Tous les statuts</option>
                            <option value="en_attente">En attente</option>
                            <option value="acceptee">Acceptées</option>
                            <option value="refusee">Refusées</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label for="date_debut" class="form-label">Date de début</label>
                        <input type="date" name="date_debut" id="date_debut" class="form-control">
                    </div>
                    
                    <div class="mb-3">
                        <label for="date_fin" class="form-label">Date de fin</label>
                        <input type="date" name="date_fin" id="date_fin" class="form-control">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="submit" class="btn btn-primary" form="filter-form">Appliquer les filtres</button>
            </div>
        </div>
    </div>
</div>

{% block javascripts %}
{{ parent() }}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialiser les tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    });
</script>
{% endblock %}

{% endblock %}