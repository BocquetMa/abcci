{% extends 'base.html.twig' %}
{% block title %}Mes notifications - ABCCI{% endblock %}

{% block body %}
<div class="container" style="max-width:760px; padding:2rem 1.5rem;">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <h1 style="font-size:1.25rem; font-weight:700; color:var(--clr-text); margin:0;">
            <i class="fas fa-bell me-2" style="color:var(--clr-primary);"></i>Mes notifications
        </h1>
        <span style="font-size:0.8rem; color:var(--clr-text-muted);">{{ notifications|length }} notification{{ notifications|length != 1 ? 's' : '' }}</span>
    </div>

    {% if notifications|length > 0 %}
        <div style="display:flex; flex-direction:column; gap:0.5rem;">
            {% for notification in notifications %}
                <div style="
                    background: var(--clr-surface);
                    border: 1px solid {{ not notification.lu ? 'var(--clr-primary-light)' : 'var(--clr-border)' }};
                    border-left: 3px solid {{ not notification.lu ? 'var(--clr-primary)' : 'var(--clr-border)' }};
                    border-radius: var(--radius);
                    padding: 1rem 1.25rem;
                    box-shadow: var(--shadow-sm);
                    {{ not notification.lu ? 'background: var(--clr-primary-muted);' : '' }}
                ">
                    <div class="d-flex align-items-start justify-content-between gap-3">
                        <div style="flex:1; min-width:0;">
                            <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                                {% if not notification.lu %}
                                    <span style="
                                        background: var(--clr-primary);
                                        color: white;
                                        font-size: 0.65rem;
                                        font-weight: 700;
                                        padding: 0.15rem 0.5rem;
                                        border-radius: 100px;
                                        letter-spacing: 0.05em;
                                        flex-shrink: 0;
                                    ">NOUVEAU</span>
                                {% endif %}
                                {% if notification.type is defined and notification.type %}
                                    <span style="
                                        background: var(--clr-bg);
                                        color: var(--clr-text-muted);
                                        font-size: 0.65rem;
                                        font-weight: 600;
                                        padding: 0.15rem 0.5rem;
                                        border-radius: 100px;
                                        border: 1px solid var(--clr-border);
                                        text-transform: uppercase;
                                        letter-spacing: 0.05em;
                                    ">{{ notification.type }}</span>
                                {% endif %}
                                <h2 style="font-size:0.9rem; font-weight:600; color:var(--clr-text); margin:0;">{{ notification.titre }}</h2>
                            </div>
                            <p style="font-size:0.85rem; color:var(--clr-text-muted); margin:0; line-height:1.5;">{{ notification.contenu }}</p>
                        </div>
                        <div style="font-size:0.75rem; color:var(--clr-text-light); white-space:nowrap; flex-shrink:0;">
                            <i class="fas fa-clock me-1"></i>{{ notification.dateCreation|date('d/m/Y à H:i') }}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div style="
            background: var(--clr-surface);
            border: 1px solid var(--clr-border);
            border-radius: var(--radius);
            padding: 3rem 2rem;
            text-align: center;
            color: var(--clr-text-muted);
            box-shadow: var(--shadow-sm);
        ">
            <i class="fas fa-bell-slash" style="font-size:2.5rem; opacity:0.25; display:block; margin-bottom:1rem;"></i>
            <p style="font-size:0.9375rem; font-weight:600; color:var(--clr-text); margin-bottom:0.4rem;">Aucune notification</p>
            <p style="font-size:0.85rem; margin:0;">Vous n'avez aucune notification pour le moment.</p>
        </div>
    {% endif %}
</div>
{% endblock %}
