{% extends 'base.html.twig' %}

{% block body %}
<div class="container mt-4">
    <h1>Mes Notifications</h1>
    
    {% for notification in notifications %}
        <div class="card mb-2 {% if not notification.lu %}bg-light{% endif %}">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <h5 class="card-title">{{ notification.titre }}</h5>
                    <small class="text-muted">
                        {{ notification.dateCreation|date('d/m/Y H:i') }}
                    </small>
                </div>
                <p class="card-text">{{ notification.contenu }}</p>
                
                <div class="d-flex justify-content-between align-items-center">
                    <span class="badge bg-info">{{ notification.type }}</span>
                    
                    {% if not notification.lu %}
                        <span class="badge bg-primary">Nouveau</span>
                    {% endif %}
                </div>
            </div>
        </div>
    {% else %}
        <div class="alert alert-info">
            Aucune notification pour le moment.
        </div>
    {% endfor %}
</div>
{% endblock %}