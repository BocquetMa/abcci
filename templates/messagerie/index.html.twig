{% extends 'base.html.twig' %}

{% block title %}Messagerie | ABCCI{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ─── Layout messagerie ───────────────────────────── */
    .msg-layout {
        display: flex;
        height: calc(100vh - 60px);
        background: var(--clr-bg);
        overflow: hidden;
    }

    /* ─── Sidebar conversations ───────────────────────── */
    .msg-sidebar {
        width: 320px;
        flex-shrink: 0;
        background: var(--clr-surface);
        border-right: 1px solid var(--clr-border);
        display: flex;
        flex-direction: column;
    }

    .msg-sidebar-head {
        padding: 1.1rem 1.25rem;
        border-bottom: 1px solid var(--clr-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }
    .msg-sidebar-head h2 {
        font-size: 0.9375rem;
        font-weight: 700;
        color: var(--clr-text);
        margin: 0;
    }
    .msg-compose-btn {
        width: 32px;
        height: 32px;
        border-radius: var(--radius-sm);
        background: var(--clr-primary-muted);
        border: none;
        color: var(--clr-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 0.85rem;
        transition: background 0.15s;
    }
    .msg-compose-btn:hover { background: var(--clr-primary-light); }

    .msg-search {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--clr-border);
        flex-shrink: 0;
    }
    .msg-search-input {
        width: 100%;
        padding: 0.5rem 0.875rem;
        border: 1px solid var(--clr-border);
        border-radius: 100px;
        background: var(--clr-bg);
        font-size: 0.82rem;
        color: var(--clr-text);
        font-family: 'Inter', sans-serif;
        transition: border-color 0.15s, box-shadow 0.15s;
        outline: none;
    }
    .msg-search-input:focus {
        border-color: var(--clr-primary);
        box-shadow: 0 0 0 3px rgba(5,150,105,0.12);
        background: white;
    }
    .msg-search-input::placeholder { color: var(--clr-text-light); }

    .msg-conv-list {
        flex: 1;
        overflow-y: auto;
    }
    .msg-conv-list::-webkit-scrollbar { width: 4px; }
    .msg-conv-list::-webkit-scrollbar-thumb { background: var(--clr-border); border-radius: 2px; }

    .msg-conv-item {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        padding: 0.875rem 1.25rem;
        border-bottom: 1px solid var(--clr-border);
        text-decoration: none;
        transition: background 0.12s;
        cursor: pointer;
    }
    .msg-conv-item:hover { background: var(--clr-bg); }
    .msg-conv-item.active { background: var(--clr-primary-muted); border-left: 2px solid var(--clr-primary); }
    .msg-conv-item.unread .msg-conv-name { font-weight: 700; }
    .msg-conv-item.unread .msg-conv-preview { color: var(--clr-text); }

    .msg-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--clr-primary), var(--clr-primary-dark));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        font-weight: 700;
        color: white;
        flex-shrink: 0;
        overflow: hidden;
    }
    .msg-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .msg-avatar.sm { width: 36px; height: 36px; font-size: 0.72rem; }

    .msg-conv-body { flex: 1; min-width: 0; }
    .msg-conv-row {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 0.2rem;
    }
    .msg-conv-name {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--clr-text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .msg-conv-time {
        font-size: 0.72rem;
        color: var(--clr-text-light);
        white-space: nowrap;
        flex-shrink: 0;
        margin-left: 0.5rem;
    }
    .msg-conv-preview {
        font-size: 0.8rem;
        color: var(--clr-text-muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .msg-unread-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--clr-primary);
        flex-shrink: 0;
    }

    /* ─── Zone principale ─────────────────────────────── */
    .msg-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1.25rem;
        background: var(--clr-bg);
        color: var(--clr-text-muted);
        text-align: center;
        padding: 2rem;
    }
    .msg-empty-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: var(--clr-primary-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        color: var(--clr-primary);
    }
    .msg-empty-title {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--clr-text);
        margin: 0;
    }
    .msg-empty-sub {
        font-size: 0.85rem;
        color: var(--clr-text-muted);
        margin: 0;
        max-width: 300px;
    }

    /* ─── Modal nouveau message ───────────────────────── */
    .msg-modal-header {
        background: linear-gradient(135deg, var(--clr-primary-dark), var(--clr-primary));
        color: white;
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
        padding: 1.1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .msg-modal-header .modal-title { font-size: 0.9375rem; font-weight: 600; color: white; }
    .msg-modal-header .btn-close { filter: invert(1); opacity: 0.8; }

    .user-search-item {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        padding: 0.75rem;
        border-radius: var(--radius-sm);
        cursor: pointer;
        transition: background 0.12s;
    }
    .user-search-item:hover { background: var(--clr-primary-muted); }
    .user-search-info { flex: 1; min-width: 0; }
    .user-search-name { font-size: 0.875rem; font-weight: 600; color: var(--clr-text); }
    .user-search-email { font-size: 0.78rem; color: var(--clr-text-muted); }
    .user-search-action {
        width: 30px; height: 30px;
        border-radius: var(--radius-sm);
        background: var(--clr-primary-muted);
        color: var(--clr-primary);
        display: flex; align-items: center; justify-content: center;
        font-size: 0.8rem;
        opacity: 0;
        transition: opacity 0.15s;
    }
    .user-search-item:hover .user-search-action { opacity: 1; }

    .search-empty-state, .search-error-state {
        text-align: center;
        padding: 2rem 1rem;
        color: var(--clr-text-muted);
    }
    .search-empty-state i { font-size: 1.75rem; display: block; margin-bottom: 0.5rem; opacity: 0.4; }
    .search-error-state { color: var(--clr-danger); }

    .search-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 1.5rem;
        color: var(--clr-text-muted);
        font-size: 0.85rem;
    }
    .search-spinner {
        width: 20px; height: 20px;
        border: 2px solid var(--clr-primary-light);
        border-top-color: var(--clr-primary);
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ─── Responsive ──────────────────────────────────── */
    @media (max-width: 768px) {
        .msg-layout { flex-direction: column; height: auto; }
        .msg-sidebar { width: 100%; height: 50vh; }
    }
</style>
{% endblock %}

{% block body %}
<div class="msg-layout">

    <!-- Sidebar -->
    <aside class="msg-sidebar">
        <div class="msg-sidebar-head">
            <h2><i class="fas fa-comment-dots me-2" style="color:var(--clr-primary);"></i>Messages</h2>
            <button class="msg-compose-btn" data-bs-toggle="modal" data-bs-target="#newMessageModal" title="Nouveau message">
                <i class="fas fa-plus"></i>
            </button>
        </div>

        <div class="msg-search">
            <input type="text" class="msg-search-input" placeholder="🔍  Rechercher une conversation..." id="conversationSearch">
        </div>

        <div class="msg-conv-list">
            {% if conversations|length > 0 %}
                {% for message in conversations %}
                    {% set otherUser = message.expediteur.id == app.user.id ? message.destinataire : message.expediteur %}
                    {% set isUnread = not message.lu and message.destinataire.id == app.user.id %}
                    <a href="{{ path('messagerie_conversation', {'id': otherUser.id}) }}"
                       class="msg-conv-item {{ isUnread ? 'unread' : '' }}">
                        <div class="msg-avatar">
                            {% if otherUser.photo %}
                                <img src="{{ asset('uploads/photos/' ~ otherUser.photo) }}" alt="{{ otherUser.prenom }}">
                            {% else %}
                                {{ otherUser.prenom|first|upper }}{{ otherUser.nom|first|upper }}
                            {% endif %}
                        </div>
                        <div class="msg-conv-body">
                            <div class="msg-conv-row">
                                <span class="msg-conv-name">{{ otherUser.prenom }} {{ otherUser.nom }}</span>
                                <span class="msg-conv-time">{{ message.dateEnvoi|date('H:i') }}</span>
                            </div>
                            <div class="msg-conv-preview">
                                {% if message.expediteur.id == app.user.id %}Vous : {% endif %}
                                {{ message.contenu|slice(0, 38) }}{% if message.contenu|length > 38 %}…{% endif %}
                            </div>
                        </div>
                        {% if isUnread %}<div class="msg-unread-dot"></div>{% endif %}
                    </a>
                {% endfor %}
            {% else %}
                <div style="padding:2rem; text-align:center; color:var(--clr-text-muted);">
                    <i class="fas fa-inbox" style="font-size:2rem; opacity:0.3; display:block; margin-bottom:0.75rem;"></i>
                    <p style="font-size:0.85rem; margin:0;">Aucune conversation</p>
                </div>
            {% endif %}
        </div>
    </aside>

    <!-- Zone principale - état vide -->
    <main class="msg-main">
        <div class="msg-empty-icon">
            <i class="far fa-comment-dots"></i>
        </div>
        <p class="msg-empty-title">Bienvenue dans votre messagerie</p>
        <p class="msg-empty-sub">Sélectionnez une conversation ou démarrez une nouvelle discussion.</p>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#newMessageModal">
            <i class="fas fa-edit me-1"></i> Nouveau message
        </button>
    </main>
</div>

<!-- Modal nouveau message -->
<div class="modal fade" id="newMessageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:460px;">
        <div class="modal-content" style="border-radius:var(--radius-lg); overflow:hidden;">
            <div class="msg-modal-header">
                <h5 class="modal-title"><i class="fas fa-edit me-2"></i>Nouveau message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body" style="padding:1.25rem;">
                <div style="position:relative; margin-bottom:1rem;">
                    <i class="fas fa-search" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--clr-text-light);font-size:0.8rem;"></i>
                    <input type="text" id="destinataireSearch" class="form-control"
                           style="padding-left:2.25rem; border-radius:100px; font-size:0.875rem;"
                           placeholder="Rechercher un utilisateur...">
                </div>
                <div id="searchStatus" class="search-loading d-none">
                    <div class="search-spinner"></div>
                    <span>Recherche...</span>
                </div>
                <div class="user-search-results"></div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Recherche dans les conversations
    const searchInput = document.getElementById('conversationSearch');
    if (searchInput) {
        searchInput.addEventListener('input', function() {
            const term = this.value.toLowerCase();
            document.querySelectorAll('.msg-conv-item').forEach(item => {
                const name = item.querySelector('.msg-conv-name')?.textContent.toLowerCase() || '';
                const preview = item.querySelector('.msg-conv-preview')?.textContent.toLowerCase() || '';
                item.style.display = (name.includes(term) || preview.includes(term)) ? 'flex' : 'none';
            });
        });
    }

    // Recherche de destinataires
    const destinataireSearch = document.getElementById('destinataireSearch');
    const searchResults = document.querySelector('.user-search-results');
    const searchStatus = document.getElementById('searchStatus');
    let searchTimeout;

    if (destinataireSearch) {
        destinataireSearch.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            const term = this.value.trim();
            if (term.length < 2) { searchResults.innerHTML = ''; return; }
            searchStatus.classList.remove('d-none');
            searchResults.innerHTML = '';
            searchTimeout = setTimeout(() => {
                fetch(`{{ path('messagerie_rechercher_utilisateurs') }}?q=${encodeURIComponent(term)}`)
                    .then(r => r.json())
                    .then(data => {
                        searchStatus.classList.add('d-none');
                        if (!data.length) {
                            searchResults.innerHTML = `<div class="search-empty-state"><i class="fas fa-search"></i><p>Aucun résultat pour "${term}"</p></div>`;
                            return;
                        }
                        searchResults.innerHTML = '';
                        data.forEach(user => {
                            const el = document.createElement('div');
                            el.className = 'user-search-item';
                            const initials = user.text.split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase();
                            el.innerHTML = `
                                <div class="msg-avatar sm">${user.photo
                                    ? `<img src="{{ asset('uploads/photos/') }}/${user.photo}" alt="${user.text}">`
                                    : initials}</div>
                                <div class="user-search-info">
                                    <div class="user-search-name">${user.text}</div>
                                    <div class="user-search-email">${user.email}</div>
                                </div>
                                <div class="user-search-action"><i class="fas fa-arrow-right"></i></div>`;
                            el.addEventListener('click', () => {
                                window.location.href = `{{ path('messagerie_conversation', {'id': 'USER_ID'}) }}`.replace('USER_ID', user.id);
                            });
                            searchResults.appendChild(el);
                        });
                    })
                    .catch(() => {
                        searchStatus.classList.add('d-none');
                        searchResults.innerHTML = `<div class="search-error-state"><i class="fas fa-exclamation-circle"></i><p>Erreur lors de la recherche</p></div>`;
                    });
            }, 300);
        });

        document.getElementById('newMessageModal').addEventListener('shown.bs.modal', () => destinataireSearch.focus());
        document.getElementById('newMessageModal').addEventListener('hidden.bs.modal', () => {
            destinataireSearch.value = '';
            searchResults.innerHTML = '';
            searchStatus.classList.add('d-none');
        });
    }
});
</script>
{% endblock %}
