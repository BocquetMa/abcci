{% extends 'base.html.twig' %}

{% block title %}{{ destinataire.prenom }} {{ destinataire.nom }} | Messagerie ABCCI{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* ─── Layout ──────────────────────────────────────── */
    .msg-layout {
        display: flex;
        height: calc(100vh - 60px);
        background: var(--clr-bg);
        overflow: hidden;
    }

    /* ─── Sidebar ─────────────────────────────────────── */
    .msg-sidebar {
        width: 300px;
        flex-shrink: 0;
        background: var(--clr-surface);
        border-right: 1px solid var(--clr-border);
        display: flex;
        flex-direction: column;
    }
    .msg-sidebar-head {
        padding: 1rem 1.1rem;
        border-bottom: 1px solid var(--clr-border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }
    .msg-sidebar-head h2 {
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--clr-text);
        margin: 0;
    }
    .msg-compose-btn {
        width: 30px; height: 30px;
        border-radius: var(--radius-sm);
        background: var(--clr-primary-muted);
        border: none;
        color: var(--clr-primary);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 0.8rem;
        transition: background 0.15s;
    }
    .msg-compose-btn:hover { background: var(--clr-primary-light); }

    .msg-search {
        padding: 0.65rem 0.875rem;
        border-bottom: 1px solid var(--clr-border);
        flex-shrink: 0;
    }
    .msg-search-input {
        width: 100%;
        padding: 0.45rem 0.875rem;
        border: 1px solid var(--clr-border);
        border-radius: 100px;
        background: var(--clr-bg);
        font-size: 0.8rem;
        color: var(--clr-text);
        font-family: 'Inter', sans-serif;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .msg-search-input:focus {
        border-color: var(--clr-primary);
        box-shadow: 0 0 0 3px rgba(5,150,105,0.1);
        background: white;
    }
    .msg-search-input::placeholder { color: var(--clr-text-light); }

    .msg-conv-list { flex: 1; overflow-y: auto; }
    .msg-conv-list::-webkit-scrollbar { width: 3px; }
    .msg-conv-list::-webkit-scrollbar-thumb { background: var(--clr-border); border-radius: 2px; }

    .msg-conv-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.8rem 1.1rem;
        border-bottom: 1px solid var(--clr-border);
        text-decoration: none;
        transition: background 0.12s;
    }
    .msg-conv-item:hover { background: var(--clr-bg); }
    .msg-conv-item.active {
        background: var(--clr-primary-muted);
        border-left: 2px solid var(--clr-primary);
    }
    .msg-conv-item.unread .msg-conv-name { font-weight: 700; }

    .msg-avatar {
        width: 38px; height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--clr-primary), var(--clr-primary-dark));
        display: flex; align-items: center; justify-content: center;
        font-size: 0.72rem; font-weight: 700; color: white;
        flex-shrink: 0; overflow: hidden;
    }
    .msg-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .msg-avatar.lg { width: 42px; height: 42px; font-size: 0.82rem; }
    .msg-avatar.xl { width: 52px; height: 52px; font-size: 1rem; }

    .msg-conv-body { flex: 1; min-width: 0; }
    .msg-conv-row {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 0.15rem;
    }
    .msg-conv-name { font-size: 0.82rem; font-weight: 600; color: var(--clr-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .msg-conv-time { font-size: 0.7rem; color: var(--clr-text-light); white-space: nowrap; margin-left: 0.4rem; flex-shrink: 0; }
    .msg-conv-preview { font-size: 0.77rem; color: var(--clr-text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .msg-unread-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--clr-primary); flex-shrink: 0; }

    /* ─── Chat area ───────────────────────────────────── */
    .msg-chat {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
        background: #F9FAFB;
    }

    /* Chat header */
    .msg-chat-header {
        background: var(--clr-surface);
        border-bottom: 1px solid var(--clr-border);
        padding: 0.9rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.875rem;
        flex-shrink: 0;
        box-shadow: 0 1px 0 var(--clr-border);
    }
    .msg-chat-header-info { flex: 1; min-width: 0; }
    .msg-chat-header-name {
        font-size: 0.9375rem;
        font-weight: 700;
        color: var(--clr-text);
        margin: 0;
    }
    .msg-chat-header-sub {
        font-size: 0.75rem;
        color: var(--clr-text-muted);
        margin: 0;
    }
    .msg-online-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        background: #10B981;
        display: inline-block;
        margin-right: 4px;
    }

    /* Messages feed */
    .msg-feed {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    .msg-feed::-webkit-scrollbar { width: 4px; }
    .msg-feed::-webkit-scrollbar-thumb { background: #D1D5DB; border-radius: 2px; }

    /* Date divider */
    .msg-date-divider {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        margin: 1rem 0 0.5rem;
    }
    .msg-date-divider::before,
    .msg-date-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--clr-border);
    }
    .msg-date-divider span {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--clr-text-muted);
        white-space: nowrap;
        letter-spacing: 0.03em;
    }

    /* Message row */
    .msg-row {
        display: flex;
        align-items: flex-end;
        gap: 0.5rem;
        margin-bottom: 0.15rem;
    }
    .msg-row.sent { flex-direction: row-reverse; }
    .msg-row.sent .msg-avatar { display: none; }

    /* Bubble */
    .msg-bubble {
        max-width: 68%;
        padding: 0.65rem 0.9rem;
        border-radius: 16px;
        font-size: 0.875rem;
        line-height: 1.55;
        word-break: break-word;
        position: relative;
    }
    .msg-bubble.received {
        background: var(--clr-surface);
        color: var(--clr-text);
        border: 1px solid var(--clr-border);
        border-bottom-left-radius: 4px;
        box-shadow: var(--shadow-sm);
    }
    .msg-bubble.sent {
        background: var(--clr-primary);
        color: white;
        border-bottom-right-radius: 4px;
    }

    .msg-meta {
        font-size: 0.68rem;
        margin-top: 0.25rem;
        padding: 0 0.25rem;
    }
    .msg-row.received .msg-meta { color: var(--clr-text-light); text-align: left; }
    .msg-row.sent .msg-meta { color: var(--clr-text-muted); text-align: right; }

    /* Attachment */
    .msg-attachment {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-top: 0.5rem;
        padding: 0.5rem 0.75rem;
        border-radius: var(--radius-sm);
        font-size: 0.8rem;
        text-decoration: none;
    }
    .msg-bubble.received .msg-attachment { background: var(--clr-bg); color: var(--clr-primary); border: 1px solid var(--clr-border); }
    .msg-bubble.sent .msg-attachment { background: rgba(255,255,255,0.15); color: white; }

    /* ─── Compose area ────────────────────────────────── */
    .msg-compose {
        background: var(--clr-surface);
        border-top: 1px solid var(--clr-border);
        padding: 1rem 1.5rem;
        flex-shrink: 0;
    }

    .msg-attachment-preview {
        display: none;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem 0.75rem;
        background: var(--clr-primary-muted);
        border: 1px solid var(--clr-primary-light);
        border-radius: var(--radius-sm);
        margin-bottom: 0.75rem;
        font-size: 0.8rem;
        color: var(--clr-primary-dark);
    }
    .msg-attachment-preview i { font-size: 1rem; }
    .msg-attachment-preview .remove-btn {
        margin-left: auto;
        background: none;
        border: none;
        color: var(--clr-text-muted);
        cursor: pointer;
        padding: 0;
        font-size: 0.85rem;
        line-height: 1;
    }
    .msg-attachment-preview .remove-btn:hover { color: var(--clr-danger); }

    .msg-compose-row {
        display: flex;
        align-items: flex-end;
        gap: 0.75rem;
    }
    .msg-compose-input-wrap {
        flex: 1;
        position: relative;
    }
    #messageContent {
        width: 100%;
        resize: none;
        border: 1px solid var(--clr-border);
        border-radius: 12px;
        padding: 0.7rem 1rem;
        font-size: 0.875rem;
        font-family: 'Inter', sans-serif;
        color: var(--clr-text);
        background: var(--clr-bg);
        outline: none;
        min-height: 44px;
        max-height: 140px;
        transition: border-color 0.15s, box-shadow 0.15s;
        line-height: 1.5;
    }
    #messageContent:focus {
        border-color: var(--clr-primary);
        box-shadow: 0 0 0 3px rgba(5,150,105,0.12);
        background: white;
    }
    #messageContent::placeholder { color: var(--clr-text-light); }

    .msg-compose-actions { display: flex; align-items: center; gap: 0.5rem; }
    .msg-attach-btn {
        width: 40px; height: 40px;
        border-radius: 10px;
        background: var(--clr-bg);
        border: 1px solid var(--clr-border);
        color: var(--clr-text-muted);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 0.9rem;
        transition: border-color 0.15s, color 0.15s;
    }
    .msg-attach-btn:hover { border-color: var(--clr-primary); color: var(--clr-primary); }

    .msg-send-btn {
        width: 40px; height: 40px;
        border-radius: 10px;
        background: var(--clr-primary);
        border: none;
        color: white;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 0.9rem;
        transition: background 0.15s, transform 0.1s;
        flex-shrink: 0;
    }
    .msg-send-btn:hover:not(:disabled) { background: var(--clr-primary-dark); transform: scale(1.05); }
    .msg-send-btn:disabled { background: #D1D5DB; cursor: not-allowed; transform: none; }

    /* ─── Modals ──────────────────────────────────────── */
    .msg-modal-header {
        background: linear-gradient(135deg, var(--clr-primary-dark), var(--clr-primary));
        color: white;
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
        padding: 1.1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .msg-modal-header .btn-close { filter: invert(1); opacity: 0.8; }
    .user-search-item {
        display: flex; align-items: center; gap: 0.75rem;
        padding: 0.7rem 0.75rem;
        border-radius: var(--radius-sm);
        cursor: pointer;
        transition: background 0.12s;
    }
    .user-search-item:hover { background: var(--clr-primary-muted); }
    .user-search-info { flex: 1; min-width: 0; }
    .user-search-name { font-size: 0.875rem; font-weight: 600; color: var(--clr-text); }
    .user-search-email { font-size: 0.78rem; color: var(--clr-text-muted); }
    .user-search-action {
        width: 28px; height: 28px; border-radius: var(--radius-sm);
        background: var(--clr-primary-muted); color: var(--clr-primary);
        display: flex; align-items: center; justify-content: center;
        font-size: 0.75rem; opacity: 0; transition: opacity 0.15s;
    }
    .user-search-item:hover .user-search-action { opacity: 1; }

    .search-loading { display: flex; align-items: center; justify-content: center; gap: 0.75rem; padding: 1.5rem; color: var(--clr-text-muted); font-size: 0.85rem; }
    .search-spinner { width: 18px; height: 18px; border: 2px solid var(--clr-primary-light); border-top-color: var(--clr-primary); border-radius: 50%; animation: spin 0.7s linear infinite; }
    .search-empty-state { text-align: center; padding: 1.5rem; color: var(--clr-text-muted); }
    .search-empty-state i { font-size: 1.5rem; display: block; margin-bottom: 0.5rem; opacity: 0.35; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ─── Responsive ──────────────────────────────────── */
    @media (max-width: 768px) {
        .msg-layout { flex-direction: column; height: auto; }
        .msg-sidebar { width: 100%; height: 45vh; border-right: none; border-bottom: 1px solid var(--clr-border); }
        .msg-chat { height: 55vh; }
        .msg-bubble { max-width: 85%; }
    }
</style>
{% endblock %}

{% block body %}
<div class="msg-layout">

    <!-- ─── Sidebar ───────────────────────────────────── -->
    <aside class="msg-sidebar">
        <div class="msg-sidebar-head">
            <h2><i class="fas fa-comment-dots me-2" style="color:var(--clr-primary);"></i>Messages</h2>
            <button class="msg-compose-btn" data-bs-toggle="modal" data-bs-target="#newMessageModal" title="Nouveau message">
                <i class="fas fa-plus"></i>
            </button>
        </div>
        <div class="msg-search">
            <input type="text" class="msg-search-input" placeholder="Rechercher..." id="conversationSearch">
        </div>
        <div class="msg-conv-list">
            {% if app.user.conversations is defined and app.user.conversations|length > 0 %}
                {% for conv in app.user.conversations %}
                    {% set otherUser = conv.expediteur.id == app.user.id ? conv.destinataire : conv.expediteur %}
                    {% set isActive = otherUser.id == destinataire.id %}
                    {% set isUnread = not conv.lu and conv.destinataire.id == app.user.id %}
                    <a href="{{ path('messagerie_conversation', {'id': otherUser.id}) }}"
                       class="msg-conv-item {{ isActive ? 'active' : '' }} {{ isUnread ? 'unread' : '' }}">
                        <div class="msg-avatar">
                            {% if otherUser.photo %}
                                <img src="{{ asset('uploads/photos/' ~ otherUser.photo) }}" alt="{{ otherUser.prenom }}">
                            {% else %}
                                {{ otherUser.prenom|first|upper }}{{ otherUser.nom|first|upper }}
                            {% endif %}
                        </div>
                        <div class="msg-conv-body">
                            <div class="msg-conv-row">
                                <span class="msg-conv-name">{{ otherUser.prenom }} {{ otherUser.nom }}</span>
                                <span class="msg-conv-time">{{ conv.dateEnvoi|date('H:i') }}</span>
                            </div>
                            <div class="msg-conv-preview">
                                {% if conv.expediteur.id == app.user.id %}Vous : {% endif %}
                                {{ conv.contenu|slice(0, 30) }}{% if conv.contenu|length > 30 %}…{% endif %}
                            </div>
                        </div>
                        {% if isUnread %}<div class="msg-unread-dot"></div>{% endif %}
                    </a>
                {% endfor %}
            {% else %}
                <div style="padding:2rem; text-align:center; color:var(--clr-text-muted);">
                    <i class="fas fa-inbox" style="font-size:1.75rem; opacity:0.25; display:block; margin-bottom:0.75rem;"></i>
                    <p style="font-size:0.82rem; margin:0;">Aucune conversation</p>
                </div>
            {% endif %}
        </div>
    </aside>

    <!-- ─── Zone de chat ──────────────────────────────── -->
    <section class="msg-chat">

        <!-- Header -->
        <div class="msg-chat-header">
            <div class="msg-avatar xl">
                {% if destinataire.photo %}
                    <img src="{{ asset('uploads/photos/' ~ destinataire.photo) }}" alt="{{ destinataire.prenom }}">
                {% else %}
                    {{ destinataire.prenom|first|upper }}{{ destinataire.nom|first|upper }}
                {% endif %}
            </div>
            <div class="msg-chat-header-info">
                <p class="msg-chat-header-name">{{ destinataire.prenom }} {{ destinataire.nom }}</p>
                <p class="msg-chat-header-sub">
                    {% for role in destinataire.roles %}
                        {% if role != 'ROLE_USER' %}
                            {{ role|replace({'ROLE_': '', '_': ' '})|title }}
                        {% endif %}
                    {% endfor %}
                    {% if destinataire.email %}· {{ destinataire.email }}{% endif %}
                </p>
            </div>
        </div>

        <!-- Messages -->
        <div class="msg-feed" id="messagesFeed">
            {% set lastDate = null %}
            {% for message in messages %}
                {% set msgDate = message.dateEnvoi|date('Y-m-d') %}
                {% if msgDate != lastDate %}
                    {% set lastDate = msgDate %}
                    <div class="msg-date-divider">
                        <span>
                            {% if msgDate == "now"|date('Y-m-d') %}Aujourd'hui
                            {% elseif msgDate == ("now - 1 day")|date('Y-m-d') %}Hier
                            {% else %}{{ message.dateEnvoi|date('d/m/Y') }}
                            {% endif %}
                        </span>
                    </div>
                {% endif %}

                {% set isSent = message.expediteur.id == app.user.id %}
                <div class="msg-row {{ isSent ? 'sent' : 'received' }}" data-message-id="{{ message.id }}">
                    {% if not isSent %}
                    <div class="msg-avatar">
                        {% if destinataire.photo %}
                            <img src="{{ asset('uploads/photos/' ~ destinataire.photo) }}" alt="{{ destinataire.prenom }}">
                        {% else %}
                            {{ destinataire.prenom|first|upper }}{{ destinataire.nom|first|upper }}
                        {% endif %}
                    </div>
                    {% endif %}
                    <div>
                        <div class="msg-bubble {{ isSent ? 'sent' : 'received' }}">
                            {{ message.contenu|nl2br }}
                            {% if message.pieceJointe %}
                                <a href="{{ asset('uploads/messages/' ~ message.pieceJointe) }}"
                                   class="msg-attachment" target="_blank">
                                    <i class="fas fa-paperclip"></i>
                                    <span>{{ message.pieceJointe }}</span>
                                </a>
                            {% endif %}
                        </div>
                        <div class="msg-meta">{{ message.dateEnvoi|date('H:i') }}</div>
                    </div>
                </div>
            {% else %}
                <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.75rem; color:var(--clr-text-muted); padding:2rem; text-align:center;">
                    <div style="width:60px;height:60px;border-radius:50%;background:var(--clr-primary-muted);display:flex;align-items:center;justify-content:center;font-size:1.5rem;color:var(--clr-primary);">
                        <i class="far fa-comment"></i>
                    </div>
                    <p style="font-size:0.875rem;font-weight:600;color:var(--clr-text);margin:0;">Démarrez la conversation</p>
                    <p style="font-size:0.8rem;margin:0;">Envoyez un premier message à {{ destinataire.prenom }}.</p>
                </div>
            {% endfor %}
        </div>

        <!-- Compose -->
        <div class="msg-compose">
            {{ form_start(form, {'attr': {'id': 'messageForm', 'enctype': 'multipart/form-data'}}) }}

            <div class="msg-attachment-preview" id="attachmentPreview">
                <i class="fas fa-paperclip"></i>
                <span id="attachmentName"></span>
                <span id="attachmentSize" style="color:var(--clr-text-light);font-size:0.72rem;"></span>
                <button type="button" class="remove-btn" id="removeAttachment" title="Supprimer la pièce jointe">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="msg-compose-row">
                <div class="msg-compose-input-wrap">
                    {{ form_widget(form.contenu, {
                        'attr': {
                            'id': 'messageContent',
                            'placeholder': 'Écrire un message...',
                            'rows': 1
                        }
                    }) }}
                </div>
                <div class="msg-compose-actions">
                    <label for="{{ form.pieceJointe.vars.id }}" class="msg-attach-btn" title="Joindre un fichier">
                        <i class="fas fa-paperclip"></i>
                    </label>
                    {{ form_widget(form.pieceJointe, {'attr': {'id': form.pieceJointe.vars.id, 'style': 'display:none;'}}) }}
                    <button type="submit" class="msg-send-btn" id="sendButton" disabled title="Envoyer">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </div>

            {{ form_end(form) }}
        </div>
    </section>
</div>

<!-- Modal nouveau message -->
<div class="modal fade" id="newMessageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:460px;">
        <div class="modal-content" style="border-radius:var(--radius-lg); overflow:hidden;">
            <div class="msg-modal-header">
                <h5 style="font-size:0.9375rem;font-weight:600;color:white;margin:0;"><i class="fas fa-edit me-2"></i>Nouveau message</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body" style="padding:1.25rem;">
                <div style="position:relative; margin-bottom:1rem;">
                    <i class="fas fa-search" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--clr-text-light);font-size:0.78rem;"></i>
                    <input type="text" id="destinataireSearch" class="form-control"
                           style="padding-left:2.25rem; border-radius:100px; font-size:0.875rem;"
                           placeholder="Rechercher un utilisateur...">
                </div>
                <div id="searchStatus" class="search-loading d-none">
                    <div class="search-spinner"></div>
                    <span>Recherche...</span>
                </div>
                <div class="user-search-results"></div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {

    // ─── Scroll en bas ───────────────────────────────────
    function scrollToBottom() {
        const feed = document.getElementById('messagesFeed');
        if (feed) feed.scrollTop = feed.scrollHeight;
    }
    scrollToBottom();

    // ─── Textarea auto-resize ────────────────────────────
    const textarea = document.getElementById('messageContent');
    const sendBtn  = document.getElementById('sendButton');
    const fileInput = document.querySelector('input[type="file"]');

    function updateSendBtn() {
        const hasText = textarea && textarea.value.trim().length > 0;
        const hasFile = fileInput && fileInput.files.length > 0;
        if (sendBtn) sendBtn.disabled = !(hasText || hasFile);
    }

    if (textarea) {
        textarea.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 140) + 'px';
            updateSendBtn();
        });

        // Entrée = envoyer, Shift+Entrée = saut de ligne
        textarea.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                if (!sendBtn.disabled) {
                    document.getElementById('messageForm').submit();
                }
            }
        });
    }

    // ─── Pièce jointe ────────────────────────────────────
    const attachPreview = document.getElementById('attachmentPreview');
    const attachName    = document.getElementById('attachmentName');
    const attachSize    = document.getElementById('attachmentSize');
    const removeBtn     = document.getElementById('removeAttachment');

    function formatSize(bytes) {
        if (bytes < 1024) return bytes + ' o';
        if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' Ko';
        return (bytes / 1048576).toFixed(1) + ' Mo';
    }

    if (fileInput) {
        fileInput.addEventListener('change', function() {
            if (this.files.length > 0) {
                const f = this.files[0];
                attachName.textContent = f.name;
                attachSize.textContent = formatSize(f.size);
                attachPreview.style.display = 'flex';
                updateSendBtn();
            }
        });
    }

    if (removeBtn) {
        removeBtn.addEventListener('click', function() {
            if (fileInput) fileInput.value = '';
            attachPreview.style.display = 'none';
            attachName.textContent = '';
            attachSize.textContent = '';
            updateSendBtn();
        });
    }

    // ─── Recherche conversations (sidebar) ───────────────
    const convSearch = document.getElementById('conversationSearch');
    if (convSearch) {
        convSearch.addEventListener('input', function() {
            const term = this.value.toLowerCase();
            document.querySelectorAll('.msg-conv-item').forEach(item => {
                const name = item.querySelector('.msg-conv-name')?.textContent.toLowerCase() || '';
                const preview = item.querySelector('.msg-conv-preview')?.textContent.toLowerCase() || '';
                item.style.display = (name.includes(term) || preview.includes(term)) ? 'flex' : 'none';
            });
        });
    }

    // ─── Recherche destinataire (modal) ──────────────────
    const destSearch  = document.getElementById('destinataireSearch');
    const searchResults = document.querySelector('.user-search-results');
    const searchStatus  = document.getElementById('searchStatus');
    let searchTimeout;

    if (destSearch) {
        destSearch.addEventListener('input', function() {
            clearTimeout(searchTimeout);
            const term = this.value.trim();
            if (term.length < 2) { searchResults.innerHTML = ''; return; }
            searchStatus.classList.remove('d-none');
            searchResults.innerHTML = '';
            searchTimeout = setTimeout(() => {
                fetch(`{{ path('messagerie_rechercher_utilisateurs') }}?q=${encodeURIComponent(term)}`)
                    .then(r => r.json())
                    .then(data => {
                        searchStatus.classList.add('d-none');
                        if (!data.length) {
                            searchResults.innerHTML = `<div class="search-empty-state"><i class="fas fa-search"></i><p>Aucun résultat pour "${term}"</p></div>`;
                            return;
                        }
                        searchResults.innerHTML = '';
                        data.forEach(user => {
                            const initials = user.text.split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase();
                            const el = document.createElement('div');
                            el.className = 'user-search-item';
                            el.innerHTML = `
                                <div class="msg-avatar">${user.photo
                                    ? `<img src="{{ asset('uploads/photos/') }}/${user.photo}" alt="${user.text}">`
                                    : initials}</div>
                                <div class="user-search-info">
                                    <div class="user-search-name">${user.text}</div>
                                    <div class="user-search-email">${user.email}</div>
                                </div>
                                <div class="user-search-action"><i class="fas fa-arrow-right"></i></div>`;
                            el.addEventListener('click', () => {
                                window.location.href = `{{ path('messagerie_conversation', {'id': 'USER_ID'}) }}`.replace('USER_ID', user.id);
                            });
                            searchResults.appendChild(el);
                        });
                    })
                    .catch(() => {
                        searchStatus.classList.add('d-none');
                        searchResults.innerHTML = `<div class="search-empty-state" style="color:var(--clr-danger);"><i class="fas fa-exclamation-circle"></i><p>Erreur lors de la recherche</p></div>`;
                    });
            }, 300);
        });

        document.getElementById('newMessageModal').addEventListener('shown.bs.modal', () => destSearch.focus());
        document.getElementById('newMessageModal').addEventListener('hidden.bs.modal', () => {
            destSearch.value = '';
            searchResults.innerHTML = '';
            searchStatus.classList.add('d-none');
        });
    }

    // ─── Auto-refresh des messages ───────────────────────
    function getLastMessageId() {
        const rows = document.querySelectorAll('.msg-row[data-message-id]');
        if (!rows.length) return 0;
        return parseInt(rows[rows.length - 1].dataset.messageId) || 0;
    }

    function addMessageToFeed(msg) {
        const feed = document.getElementById('messagesFeed');
        const isSent = msg.isSent;

        // Divider de date si besoin
        const lastDivider = feed.querySelector('.msg-date-divider:last-of-type span');
        if (!lastDivider || lastDivider.textContent !== msg.dateLabel) {
            const div = document.createElement('div');
            div.className = 'msg-date-divider';
            div.innerHTML = `<span>${msg.dateLabel}</span>`;
            feed.appendChild(div);
        }

        const row = document.createElement('div');
        row.className = `msg-row ${isSent ? 'sent' : 'received'}`;
        row.dataset.messageId = msg.id;

        let avatarHtml = '';
        if (!isSent) {
            avatarHtml = `<div class="msg-avatar">{{ destinataire.prenom|first|upper }}{{ destinataire.nom|first|upper }}</div>`;
        }

        let attachHtml = '';
        if (msg.pieceJointe) {
            attachHtml = `<a href="/uploads/messages/${msg.pieceJointe}" class="msg-attachment" target="_blank">
                <i class="fas fa-paperclip"></i><span>${msg.pieceJointe}</span></a>`;
        }

        row.innerHTML = `${avatarHtml}
            <div>
                <div class="msg-bubble ${isSent ? 'sent' : 'received'}">${msg.contenu}${attachHtml}</div>
                <div class="msg-meta">${msg.heure}</div>
            </div>`;

        feed.appendChild(row);
        scrollToBottom();
    }

    setInterval(() => {
        const lastId = getLastMessageId();
        fetch(`{{ path('messagerie_nouveaux_messages', {'id': destinataire.id}) }}?lastId=${lastId}`)
            .then(r => r.json())
            .then(data => {
                if (data && data.length) {
                    data.forEach(msg => addMessageToFeed(msg));
                }
            })
            .catch(() => {});
    }, 5000);
});
</script>
{% endblock %}
