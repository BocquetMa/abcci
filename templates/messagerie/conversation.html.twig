    <script>
    // Force le bouton d'envoi à être actif dès le chargement de la page
    document.addEventListener('DOMContentLoaded', function() {
        // Récupérer les éléments
        const sendButton = document.getElementById('send-button');
        const messageInput = document.getElementById('message-input');
        
        // Activer le bouton d'envoi
        if (sendButton) {
            sendButton.disabled = false;
        }
        
        // Réactiver le bouton à chaque saisie
        if (messageInput) {
            messageInput.addEventListener('input', function() {
                sendButton.disabled = false;
            });
        }
    });
</script>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const messageInput = document.getElementById('message-input');
            const sendButton = document.getElementById('send-button');
            const chatMessages = document.getElementById('chatMessages');
            const fileInput = document.getElementById('{{ form.pieceJointe.vars.id }}');
            const attachmentPreview = document.getElementById('attachment-preview');
            const attachmentName = document.querySelector('.attachment-name');
            const attachmentSize = document.querySelector('.attachment-size');
            const removeAttachment = document.getElementById('remove-attachment');
            
            // Activer initialement le bouton si le champ n'est pas vide
            if (messageInput && messageInput.value.trim() !== '') {
                sendButton.disabled = false;
            }
            
            // Faire défiler jusqu'au dernier message
            scrollToBottom();
            
            // Activer/désactiver le bouton d'envoi en fonction du contenu
            if (messageInput) {
                messageInput.addEventListener('input', function() {
                    sendButton.disabled = this.value.trim() === '' && (!fileInput || !fileInput.files.length);
                    
                    // Ajuster automatiquement la hauteur du textarea
                    this.style.height = 'auto';
                    this.style.height = (this.scrollHeight) + 'px';
                });
                
                // S'assurer que l'état initial du bouton est correct
                sendButton.disabled = messageInput.value.trim() === '' && (!fileInput || !fileInput.files.length);
            }
            
            // Envoyer le message avec la touche Entrée (sauf si Shift est pressé)
            if (messageInput) {
                messageInput.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter' && !e.shiftKey) {
                        e.preventDefault();
                        if (!sendButton.disabled) {
                            document.getElementById('message-form').submit();
                        }
                    }
                });
            }
            
            // Gérer l'aperçu des pièces jointes
            if (fileInput) {
                fileInput.addEventListener('change', function() {
                    if (this.files.length) {
                        const file = this.files[0];
                        attachmentName.textContent = file.name;
                        attachmentSize.textContent = formatFileSize(file.size);
                        attachmentPreview.style.display = 'flex';
                        sendButton.disabled = false;
                    } else {
                        attachmentPreview.style.display = 'none';
                        sendButton.disabled = messageInput.value.trim() === '';
                    }
                });
            }
            
            // Supprimer la pièce jointe
            if (removeAttachment) {
                removeAttachment.addEventListener('click', function() {
                    fileInput.value = '';
                    attachmentPreview.style.display = 'none';
                    sendButton.disabled = messageInput.value.trim() === '';
                });
            }
            
            // Recherche d'utilisateurs pour nouveau message
            const destinataireSearch = document.getElementById('destinataireSearch');
            const searchResults = document.querySelector('.user-search-results');
            
            if (destinataireSearch) {
                let searchTimeout;
                
                destinataireSearch.addEventListener('input', function() {
                    clearTimeout(searchTimeout);
                    const searchTerm = this.value.trim();
                    
                    if (searchTerm.length < 2) {
                        searchResults.innerHTML = '';
                        return;
                    }
                    
                    searchTimeout = setTimeout(() => {
                        fetch(`{{ path('messagerie_rechercher_utilisateurs') }}?q=${searchTerm}`)
                            .then(response => response.json())
                            .then(data => {
                                searchResults.innerHTML = '';
                                
                                if (data.length === 0) {
                                    searchResults.innerHTML = `
                                        <div class="text-center py-3 text-muted">
                                            <i class="fas fa-search me-2"></i>Aucun utilisateur trouvé
                                        </div>
                                    `;
                                    return;
                                }
                                
                                data.forEach(user => {
                                    const userElement = document.createElement('div');
                                    userElement.className = 'user-search-item';
                                    userElement.innerHTML = `
                                        <div class="user-search-avatar">
                                            ${user.photo 
                                                ? `<img src="{{ asset('uploads/photos/') }}/${user.photo}" alt="${user.text}">`
                                                : `<div class="d-flex align-items-center justify-content-center bg-secondary h-100 w-100">
                                                    <i class="fas fa-user text-white"></i>
                                                  </div>`
                                            }
                                        </div>
                                        <div class="user-search-info">
                                            <div class="user-search-name">${user.text}</div>
                                            <div class="user-search-email">${user.email}</div>
                                        </div>
                                    `;
                                    
                                    userElement.addEventListener('click', function() {
                                        window.location.href = `{{ path('messagerie_conversation', {'id': 'USER_ID'}) }}`.replace('USER_ID', user.id);
                                    });
                                    
                                    searchResults.appendChild(userElement);
                                });
                            })
                            .catch(error => {
                                console.error('Erreur lors de la recherche:', error);
                                searchResults.innerHTML = `
                                    <div class="text-center py-3 text-danger">
                                        <i class="fas fa-exclamation-circle me-2"></i>Erreur lors de la recherche
                                    </div>
                                `;
                            });
                    }, 300);
                });
            }
            
            // Rafraîchir les nouveaux messages toutes les 5 secondes
            let lastMessageId = getLastMessageId();
            
            setInterval(function() {
                checkNewMessages();
            }, 5000);
            
            function checkNewMessages() {
                const currentLastMessageId = getLastMessageId();
                
                if (currentLastMessageId > 0) {
                    fetch(`{{ path('messagerie_nouveaux_messages', {'id': destinataire.id}) }}?lastId=${currentLastMessageId}`)
                        .then(response => response.json())
                        .then(data => {
                            if (data.messages && data.messages.length > 0) {
                                let currentDate = getCurrentDateFromDivider();
                                
                                data.messages.forEach(message => {
                                    const messageDate = new Date(message.dateEnvoi).toISOString().split('T')[0];
                                    
                                    if (currentDate !== messageDate) {
                                        const today = new Date().toISOString().split('T')[0];
                                        const yesterday = new Date(Date.now() - 86400000).toISOString().split('T')[0];
                                        
                                        let dateText;
                                        if (messageDate === today) {
                                            dateText = 'Aujourd\'hui';
                                        } else if (messageDate === yesterday) {
                                            dateText = 'Hier';
                                        } else {
                                            const parts = messageDate.split('-');
                                            dateText = `${parts[2]}/${parts[1]}/${parts[0]}`;
                                        }
                                        
                                        const dateDivider = document.createElement('div');
                                        dateDivider.className = 'message-date-divider';
                                        dateDivider.textContent = dateText;
                                        chatMessages.appendChild(dateDivider);
                                        
                                        currentDate = messageDate;
                                    }
                                    
                                    const messageGroup = document.createElement('div');
                                    messageGroup.className = `message-group ${message.estExpediteur ? 'sent' : 'received'}`;
                                    messageGroup.dataset.messageId = message.id;
                                    
                                    messageGroup.innerHTML = `
                                        <div class="message-bubble">
                                            ${message.contenu.replace(/\n/g, '<br>')}
                                        </div>
                                        <div class="message-time">
                                            ${message.dateEnvoi}
                                            ${message.estExpediteur ? '<i class="fas fa-check ms-1" title="Envoyé"></i>' : ''}
                                        </div>
                                    `;
                                    
                                    chatMessages.appendChild(messageGroup);
                                });
                                
                                scrollToBottom();
                            }
                        })
                        .catch(error => {
                            console.error('Erreur lors de la vérification des nouveaux messages:', error);
                        });
                }
            }
            
            function getLastMessageId() {
                const messageElements = document.querySelectorAll('.message-group');
                if (messageElements.length > 0) {
                    const lastElement = messageElements[messageElements.length - 1];
                    return parseInt(lastElement.dataset.messageId || 0);
                }
                return 0;
            }
            
            function getCurrentDateFromDivider() {
                const dividers = document.querySelectorAll('.message-date-divider');
                if (dividers.length > 0) {
                    const lastDivider = dividers[dividers.length - 1];
                    const dividerText = lastDivider.textContent.trim();
                    
                    const today = new Date();
                    const yesterday = new Date(Date.now() - 86400000);
                    
                    if (dividerText === 'Aujourd\'hui') {
                        return today.toISOString().split('T')[0];
                    } else if (dividerText === 'Hier') {
                        return yesterday.toISOString().split('T')[0];
                    } else {
                        // Format: dd/mm/yyyy
                        const parts = dividerText.split('/');
                        return `${parts[2]}-${parts[1]}-${parts[0]}`;
                    }
                }
                return null;
            }
            
            function scrollToBottom() {
                if (chatMessages) {
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                }
            }
            
            function formatFileSize(bytes) {
                if (bytes < 1024) {
                    return bytes + ' octets';
                } else if (bytes < 1048576) {
                    return (bytes / 1024).toFixed(1) + ' Ko';
                } else {
                    return (bytes / 1048576).toFixed(1) + ' Mo';
                }
            }
        });
    </script>
{% endblock %}