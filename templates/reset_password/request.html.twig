{% extends 'base.html.twig' %}

{% block title %}Réinitialiser votre mot de passe - ABCCI{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        body { background: #f6f6f6; }
        .reset-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }
        .reset-card {
            background: white;
            border: 1px solid #e5e5e5;
            border-radius: 4px;
            padding: 2rem;
            width: 100%;
            max-width: 440px;
            box-shadow: 0 2px 6px rgba(0,0,18,0.06);
        }
    </style>
{% endblock %}

{% block body %}
<div class="reset-page">
    <div class="reset-card">
        <div class="text-center fr-mb-3w">
            <span class="fr-icon-lock-line fr-icon--xl" aria-hidden="true" style="color:#003189;"></span>
            <h1 class="fr-h4 fr-mt-1w">Réinitialiser votre mot de passe</h1>
            <p style="color:#555; font-size:0.9rem;">
                Entrez votre adresse e-mail et nous vous enverrons un lien pour réinitialiser votre mot de passe.
            </p>
        </div>

        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="fr-alert fr-alert--error fr-alert--sm fr-mb-2w" role="alert">
                <p>{{ flash_error }}</p>
            </div>
        {% endfor %}

        {{ form_start(requestForm) }}
            <div class="fr-input-group">
                {{ form_label(requestForm.email, 'Adresse e-mail', {'label_attr': {'class': 'fr-label'}}) }}
                {{ form_widget(requestForm.email, {'attr': {'class': 'fr-input', 'placeholder': 'votre@email.com', 'autocomplete': 'email'}}) }}
                {{ form_errors(requestForm.email) }}
            </div>

            <button class="fr-btn w-100 fr-mt-2w" style="justify-content:center;">
                <span class="fr-icon-mail-line me-1" aria-hidden="true"></span>
                Envoyer le lien de réinitialisation
            </button>
        {{ form_end(requestForm) }}

        <div class="text-center fr-mt-2w">
            <a href="{{ path('app_login') }}" class="fr-btn fr-btn--tertiary fr-icon-arrow-left-line fr-btn--icon-left">
                Retour à la connexion
            </a>
        </div>
    </div>
</div>
{% endblock %}
