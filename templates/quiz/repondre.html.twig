{% extends 'base.html.twig' %}

{% block title %}{{ quiz.titre }} | Quiz{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .quiz-container {
            background-color: white;
            border-radius: var(--border-radius);
            box-shadow: var(--box-shadow);
            padding: 2rem;
            margin: 2rem auto;
            max-width: 900px;
        }
        
        .page-header {
            position: relative;
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #f1f3f5;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .page-header h1 {
            color: var(--dark);
            font-size: 1.8rem;
            font-weight: 700;
            margin: 0;
        }
        
        .page-header:after {
            content: '';
            position: absolute;
            left: 0;
            bottom: -1px;
            width: 80px;
            height: 3px;
            background: linear-gradient(90deg, var(--primary), var(--primary-light));
        }
        
        .timer-container {
            display: flex;
            align-items: center;
            background-color: #f8f9fa;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            font-weight: 600;
        }
        
        .timer-container i {
            color: var(--primary);
            margin-right: 0.5rem;
            font-size: 1.1rem;
        }
        
        .timer-warning {
            color: #dc3545;
            animation: pulse 1s infinite;
        }
        
        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.5; }
            100% { opacity: 1; }
        }
        
        .question-container {
            margin-bottom: 3rem;
            border: 1px solid #f1f3f5;
            border-radius: 10px;
            overflow: hidden;
        }
        
        .question-header {
            background-color: var(--primary-light);
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid #f1f3f5;
        }
        
        .question-number {
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--primary);
            margin-bottom: 0.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .question-points {
            background-color: var(--primary);
            color: white;
            font-size: 0.8rem;
            padding: 0.2rem 0.6rem;
            border-radius: 50px;
        }
        
        .question-content {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--dark);
            line-height: 1.5;
        }
        
        .question-body {
            padding: 1.5rem;
        }
        
        .form-check {
            margin-bottom: 1.25rem;
            padding-left: 2rem;
        }
        
        .form-check-input {
            width: 1.2rem;
            height: 1.2rem;
            margin-top: 0.25rem;
            cursor: pointer;
        }
        
        .form-check-label {
            padding-left: 0.5rem;
            cursor: pointer;
        }
        
        .form-check:last-child {
            margin-bottom: 0;
        }
        
        .text-answer {
            margin-top: 1rem;
        }
        
        .action-buttons {
            display: flex;
            justify-content: space-between;
            margin-top: 2rem;
        }
        
        .btn-navigation {
            display: inline-flex;
            align-items: center;
            padding: 0.75rem 1.5rem;
            border-radius: 50px;
            font-weight: 500;
            transition: all 0.3s;
        }
        
        .btn-navigation i {
            margin-right: 0.5rem;
        }
        
        .btn-navigation.btn-prev {
            background-color: #f8f9fa;
            border: 1px solid #dee2e6;
            color: var(--secondary);
        }
        
        .btn-navigation.btn-prev:hover {
            background-color: #e9ecef;
            color: var(--dark);
        }
        
        .btn-navigation.btn-save {
            background-color: #e6f0ff;
            border: 1px solid var(--primary-light);
            color: var(--primary);
        }
        
        .btn-navigation.btn-save:hover {
            background-color: var(--primary-light);
        }
        
        .btn-navigation.btn-finish {
            background: linear-gradient(45deg, var(--primary), var(--primary-dark));
            border: none;
            color: white;
            box-shadow: 0 4px 6px rgba(13, 110, 253, 0.15);
        }
        
        .btn-navigation.btn-finish:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 10px rgba(13, 110, 253, 0.2);
        }
        
        .btn-navigation.btn-finish i {
            margin-right: 0.5rem;
        }
        
        .progress-container {
            margin-bottom: 2rem;
        }
        
        .progress-label {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
            color: var(--secondary);
        }
        
        .progress {
            height: 8px;
            border-radius: 4px;
            background-color: #e9ecef;
        }
        
        .progress-bar {
            background: linear-gradient(90deg, var(--primary), var(--primary-dark));
            border-radius: 4px;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container quiz-container">
    <form method="post" id="quiz-form">
        <div class="page-header">
            <h1>{{ quiz.titre }}</h1>
            
            <div class="timer-container" id="timer">
                <i class="far fa-clock"></i>
                <span id="timer-display">--:--</span>
            </div>
        </div>
        
        <div class="progress-container">
            <div class="progress-label">
                <span>Progression</span>
                <span id="progress-text">Question 1 sur {{ questions|length }}</span>
            </div>
            <div class="progress">
                <div class="progress-bar" role="progressbar" style="width: {{ (100 / questions|length)|round }}%" aria-valuenow="{{ (100 / questions|length)|round }}" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
        </div>
        
        {% for question in questions %}
            <div class="question-container" id="question-{{ question.id }}" style="{{ loop.first ? '' : 'display: none;' }}">
                <div class="question-header">
                    <div class="question-number">
                        <span>Question {{ loop.index }} sur {{ questions|length }}</span>
                        <span class="question-points">{{ question.points }} point{{ question.points > 1 ? 's' : '' }}</span>
                    </div>
                    <div class="question-content">
                        {{ question.enonce|nl2br }}
                    </div>
                </div>
                <div class="question-body">
                    {% if question.type == 'texte' %}
                        <div class="text-answer">
                            <textarea name="question_texte_{{ question.id }}" class="form-control" rows="4" placeholder="Saisissez votre réponse ici...">{{ reponses[question.id][0] is defined ? reponses[question.id][0] : '' }}</textarea>
                        </div>
                    {% elseif question.type == 'vrai_faux' or question.type == 'choix_unique' %}
                        {% for reponse in question.reponses %}
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="question_{{ question.id }}" id="reponse-{{ reponse.id }}" value="{{ reponse.id }}" {{ reponses[question.id] is defined and reponse.id in reponses[question.id] ? 'checked' : '' }}>
                                <label class="form-check-label" for="reponse-{{ reponse.id }}">
                                    {{ reponse.texte }}
                                </label>
                            </div>
                        {% endfor %}
                    {% elseif question.type == 'choix_multiple' %}
                        {% for reponse in question.reponses %}
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="question_{{ question.id }}[]" id="reponse-{{ reponse.id }}" value="{{ reponse.id }}" {{ reponses[question.id] is defined and reponse.id in reponses[question.id] ? 'checked' : '' }}>
                                <label class="form-check-label" for="reponse-{{ reponse.id }}">
                                    {{ reponse.texte }}
                                </label>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
        {% endfor %}
        
        <div class="action-buttons">
            <button type="button" id="btn-prev" class="btn-navigation btn-prev" style="visibility: hidden;">
                <i class="fas fa-arrow-left"></i> Question précédente
            </button>
            
            <div>
                <button type="submit" name="sauvegarder" class="btn-navigation btn-save" id="btn-save">
                    <i class="fas fa-save"></i> Sauvegarder
                </button>
                
                <button type="submit" name="terminer" class="btn-navigation btn-finish" id="btn-finish">
                    <i class="fas fa-check-circle"></i> Terminer le quiz
                </button>
            </div>
            
            <button type="button" id="btn-next" class="btn-navigation btn-primary">
                Question suivante <i class="fas fa-arrow-right"></i>
            </button>
        </div>
    </form>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Variables pour la navigation entre questions
    const questions = document.querySelectorAll('.question-container');
    const btnPrev = document.getElementById('btn-prev');
    const btnNext = document.getElementById('btn-next');
    const btnSave = document.getElementById('btn-save');
    const btnFinish = document.getElementById('btn-finish');
    const progressText = document.getElementById('progress-text');
    const progressBar = document.querySelector('.progress-bar');
    const timerDisplay = document.getElementById('timer-display');
    
    let currentQuestionIndex = 0;
    const totalQuestions = {{ questions|length }};
    
    // Timer
    let timeRemaining = {{ tempsRestantEnSecondes }};
    const timerContainer = document.querySelector('.timer-container');
    
    function updateTimer() {
        const minutes = Math.floor(timeRemaining / 60);
        const seconds = timeRemaining % 60;
        
        timerDisplay.textContent = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
        
        // Ajouter une classe pour l'alerte visuelle si moins de 5 minutes restantes
        if (timeRemaining <= 300) {
            timerContainer.classList.add('timer-warning');
        }
        
        // Si le temps est écoulé, soumettre automatiquement le formulaire
        if (timeRemaining <= 0) {
            document.getElementById('quiz-form').submit();
            return;
        }
        
        timeRemaining--;
        setTimeout(updateTimer, 1000);
    }
    
    updateTimer();
    
    // Fonctions pour la navigation entre questions
    function showQuestion(index) {
        // Masquer toutes les questions
        questions.forEach(q => q.style.display = 'none');
        
        // Afficher la question courante
        questions[index].style.display = 'block';
        
        // Mettre à jour la barre de progression
        const progressPercentage = ((index + 1) / totalQuestions) * 100;
        progressBar.style.width = `${progressPercentage}%`;
        progressBar.setAttribute('aria-valuenow', progressPercentage);
        progressText.textContent = `Question ${index + 1} sur ${totalQuestions}`;
        
        // Mettre à jour les boutons de navigation
        btnPrev.style.visibility = index === 0 ? 'hidden' : 'visible';
        btnNext.style.visibility = index === totalQuestions - 1 ? 'hidden' : 'visible';
        
        // Mettre le focus sur la première option de réponse de la question
        const firstInput = questions[index].querySelector('input, textarea');
        if (firstInput) {
            firstInput.focus();
        }
        
        currentQuestionIndex = index;
    }
    
    // Navigation vers la question précédente
    btnPrev.addEventListener('click', function() {
        if (currentQuestionIndex > 0) {
            showQuestion(currentQuestionIndex - 1);
        }
    });
    
    // Navigation vers la question suivante
    btnNext.addEventListener('click', function() {
        if (currentQuestionIndex < totalQuestions - 1) {
            showQuestion(currentQuestionIndex + 1);
        }
    });
    
    // Soumettre automatiquement le formulaire si le bouton "Sauvegarder" est cliqué
    btnSave.addEventListener('click', function() {
        document.getElementById('quiz-form').appendChild(
            document.createElement('input')
        ).setAttribute('name', 'sauvegarder');
    });
    
    // Soumettre automatiquement le formulaire si le bouton "Terminer" est cliqué
    btnFinish.addEventListener('click', function() {
        if (confirm('Êtes-vous sûr de vouloir terminer ce quiz ? Cette action est définitive.')) {
            document.getElementById('quiz-form').appendChild(
                document.createElement('input')
            ).setAttribute('name', 'terminer');
        } else {
            return false;
        }
    });
    
    // Initialiser la première question
    showQuestion(0);
});
</script>
{% endblock %}