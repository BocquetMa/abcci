{% extends 'base.html.twig' %}

{% block title %}Quiz - {{ formation.titre }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .quiz-container {
            background-color: white;
            border-radius: var(--border-radius);
            box-shadow: var(--box-shadow);
            padding: 2rem;
            margin: 2rem auto;
            max-width: 1000px;
        }
        
        .page-header {
            position: relative;
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid #f1f3f5;
        }
        
        .page-header h1 {
            color: var(--dark);
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }
        
        .page-header:after {
            content: '';
            position: absolute;
            left: 0;
            bottom: -1px;
            width: 80px;
            height: 3px;
            background: linear-gradient(90deg, var(--primary), var(--primary-light));
        }
        
        .formation-link {
            color: var(--primary);
            display: inline-flex;
            align-items: center;
            font-weight: 500;
            margin-bottom: 1rem;
            transition: all 0.2s;
        }
        
        .formation-link:hover {
            transform: translateX(-3px);
        }
        
        .formation-link i {
            margin-right: 0.5rem;
        }
        
        .quiz-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }
        
        .quiz-card {
            background-color: white;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            transition: all 0.3s ease;
            border: 1px solid #f1f3f5;
        }
        
        .quiz-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        }
        
        .quiz-header {
            padding: 1.5rem;
            background-color: var(--primary-light);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }
        
        .quiz-title {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--primary-dark);
            margin-bottom: 0.5rem;
        }
        
        .quiz-meta {
            display: flex;
            justify-content: space-between;
            font-size: 0.85rem;
            color: var(--secondary);
        }
        
        .quiz-body {
            padding: 1.5rem;
        }
        
        .quiz-description {
            color: var(--secondary);
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
            min-height: 60px;
        }
        
        .quiz-footer {
            display: flex;
            justify-content: space-between;
            padding: 1rem 1.5rem;
            background-color: rgba(0, 0, 0, 0.01);
            border-top: 1px solid rgba(0, 0, 0, 0.05);
        }
        
        .badge-success {
            background-color: rgba(40, 167, 69, 0.1);
            color: #28a745;
            border: 1px solid rgba(40, 167, 69, 0.2);
            padding: 0.35rem 0.6rem;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        
        .badge-warning {
            background-color: rgba(255, 193, 7, 0.1);
            color: #ffc107;
            border: 1px solid rgba(255, 193, 7, 0.2);
            padding: 0.35rem 0.6rem;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        
        .badge-danger {
            background-color: rgba(220, 53, 69, 0.1);
            color: #dc3545;
            border: 1px solid rgba(220, 53, 69, 0.2);
            padding: 0.35rem 0.6rem;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
        }
        
        .quiz-stats {
            display: flex;
            justify-content: space-between;
            margin-bottom: 1rem;
            font-size: 0.85rem;
        }
        
        .quiz-stats-item {
            display: flex;
            align-items: center;
            color: var(--secondary);
        }
        
        .quiz-stats-item i {
            color: var(--primary);
            margin-right: 0.5rem;
        }
        
        .btn-quiz {
            background: linear-gradient(45deg, var(--primary), var(--primary-dark));
            border: none;
            color: white;
            padding: 0.5rem 1.25rem;
            border-radius: 50px;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            box-shadow: 0 4px 6px rgba(13, 110, 253, 0.2);
        }
        
        .btn-quiz:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(13, 110, 253, 0.25);
            color: white;
        }
        
        .btn-quiz i {
            margin-right: 0.5rem;
        }
        
        .empty-state {
            text-align: center;
            padding: 3rem;
            background-color: #f8f9fa;
            border-radius: 10px;
            margin-top: 2rem;
        }
        
        .empty-state-icon {
            font-size: 3rem;
            color: var(--secondary);
            margin-bottom: 1rem;
        }
        
        .empty-state h3 {
            font-size: 1.5rem;
            margin-bottom: 1rem;
            color: var(--dark);
        }
        
        .empty-state p {
            color: var(--secondary);
            max-width: 600px;
            margin: 0 auto 1.5rem;
        }
</style>
{% endblock %}

{% block body %}
<div class="container quiz-container">
    <a href="{{ path('formation_voir', {id: formation.id}) }}" class="formation-link">
        <i class="fas fa-arrow-left"></i> Retour à la formation
    </a>
    
    <div class="page-header">
        <h1>Quiz de la formation "{{ formation.titre }}"</h1>
        <p class="text-muted">Testez vos connaissances et validez vos acquis</p>
    </div>
    
    {% if quizzes|length > 0 %}
        <div class="quiz-grid">
            {% for quiz in quizzes %}
                {% if quiz.actif or is_granted('ROLE_FORMATEUR') or is_granted('ROLE_ADMIN') %}
                    <div class="quiz-card">
                        <div class="quiz-header">
                            <h2 class="quiz-title">{{ quiz.titre }}</h2>
                            <div class="quiz-meta">
                                <span><i class="far fa-clock me-1"></i> {{ quiz.tempsLimite }} min</span>
                                <span><i class="fas fa-question-circle me-1"></i> {{ quiz.questions|length }} questions</span>
                            </div>
                        </div>
                        <div class="quiz-body">
                            <div class="quiz-description">
                                {{ quiz.description|slice(0, 120) }}{% if quiz.description|length > 120 %}...{% endif %}
                            </div>
                            
                            <div class="quiz-stats">
                                <div class="quiz-stats-item">
                                    <i class="fas fa-trophy"></i> 
                                    Score minimum: {{ quiz.scoreReussite }}%
                                </div>
                                
                                {% if app.user.getMeilleurScorePourQuiz(quiz) is not null %}
                                    <div class="quiz-stats-item">
                                        <i class="fas fa-chart-line"></i>
                                        Meilleur score: {{ app.user.getMeilleurScorePourQuiz(quiz) }}%
                                    </div>
                                {% endif %}
                            </div>
                            
                            {% if app.user.aReussiQuiz(quiz) %}
                                <span class="badge-success d-inline-block mb-2">
                                    <i class="fas fa-check-circle me-1"></i> Quiz réussi
                                </span>
                            {% endif %}
                            
                            {% if not quiz.actif and (is_granted('ROLE_FORMATEUR') or is_granted('ROLE_ADMIN')) %}
                                <span class="badge-danger d-inline-block mb-2">
                                    <i class="fas fa-ban me-1"></i> Inactif (visible uniquement par les formateurs)
                                </span>
                            {% endif %}
                        </div>
                        <div class="quiz-footer">
                            <span>{{ app.user.getNombreTentativesPourQuiz(quiz) }} tentative(s)</span>
                            <a href="{{ path('quiz_details', {id: quiz.id}) }}" class="btn-quiz">
                                <i class="fas fa-play-circle"></i> Accéder
                            </a>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    {% else %}
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="fas fa-scroll"></i>
            </div>
            <h3>Aucun quiz disponible</h3>
            <p>Il n'y a pas encore de quiz disponible pour cette formation. Revenez plus tard ou contactez votre formateur pour plus d'informations.</p>
        </div>
    {% endif %}
</div>
{% endblock %}