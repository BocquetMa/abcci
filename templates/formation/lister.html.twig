{% extends 'base.html.twig' %}
{% block title %}Formations - ABCCI{% endblock %}

{% block body %}
<div class="container" style="max-width:1200px; padding:2rem 1.5rem;">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <div>
            <h1 style="font-size:1.25rem; font-weight:700; color:var(--clr-text); margin:0 0 0.2rem;">Formations disponibles</h1>
            <p style="font-size:0.85rem; color:var(--clr-text-muted); margin:0;">{{ formations|length }} formation{{ formations|length != 1 ? 's' : '' }} trouvée{{ formations|length != 1 ? 's' : '' }}</p>
        </div>
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('formation_ajouter') }}" class="btn btn-primary btn-sm">
                <i class="fas fa-plus me-1"></i>Nouvelle formation
            </a>
        {% endif %}
    </div>

    <!-- Filtres -->
    <div style="background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius); margin-bottom:1.5rem; box-shadow:var(--shadow-sm); overflow:hidden;">
        <button type="button" id="filter-toggle"
                style="width:100%; display:flex; align-items:center; justify-content:space-between; padding:0.875rem 1.25rem; background:none; border:none; font-size:0.875rem; font-weight:600; color:var(--clr-text); cursor:pointer;">
            <span><i class="fas fa-sliders-h me-2" style="color:var(--clr-primary);"></i>Filtrer les formations</span>
            <i class="fas fa-chevron-down" id="filter-chevron" style="font-size:0.75rem; color:var(--clr-text-muted); transition:transform 0.2s;"></i>
        </button>
        <div id="filter-body" style="border-top:1px solid var(--clr-border); padding:1.25rem;">
            {{ form_start(searchForm, {attr: {class: 'row g-3'}}) }}
                <div class="col-md-6 col-lg-3">
                    <label style="font-size:0.8rem; font-weight:600; color:var(--clr-text-muted); display:block; margin-bottom:0.35rem;">Thème</label>
                    {{ form_widget(searchForm.theme, {attr: {class: 'form-select form-select-sm'}}) }}
                </div>
                <div class="col-md-6 col-lg-3">
                    <label style="font-size:0.8rem; font-weight:600; color:var(--clr-text-muted); display:block; margin-bottom:0.35rem;">Niveau</label>
                    {{ form_widget(searchForm.niveau, {attr: {class: 'form-select form-select-sm'}}) }}
                </div>
                <div class="col-6 col-lg-3">
                    <label style="font-size:0.8rem; font-weight:600; color:var(--clr-text-muted); display:block; margin-bottom:0.35rem;">Durée min (h)</label>
                    {{ form_widget(searchForm.dureeMin, {attr: {class: 'form-control form-control-sm', placeholder: 'Ex: 7'}}) }}
                </div>
                <div class="col-6 col-lg-3">
                    <label style="font-size:0.8rem; font-weight:600; color:var(--clr-text-muted); display:block; margin-bottom:0.35rem;">Durée max (h)</label>
                    {{ form_widget(searchForm.dureeMax, {attr: {class: 'form-control form-control-sm', placeholder: 'Ex: 35'}}) }}
                </div>
                <div class="col-6 col-lg-3">
                    <label style="font-size:0.8rem; font-weight:600; color:var(--clr-text-muted); display:block; margin-bottom:0.35rem;">Prix min (€)</label>
                    {{ form_widget(searchForm.prixMin, {attr: {class: 'form-control form-control-sm', placeholder: 'Ex: 100'}}) }}
                </div>
                <div class="col-6 col-lg-3">
                    <label style="font-size:0.8rem; font-weight:600; color:var(--clr-text-muted); display:block; margin-bottom:0.35rem;">Prix max (€)</label>
                    {{ form_widget(searchForm.prixMax, {attr: {class: 'form-control form-control-sm', placeholder: 'Ex: 1000'}}) }}
                </div>

                {% if searchForm.motsCles is defined %}
                <div class="col-12">
                    <label style="font-size:0.8rem; font-weight:600; color:var(--clr-text-muted); display:block; margin-bottom:0.5rem;">Mots-clés</label>
                    <div style="display:flex; flex-wrap:wrap; gap:0.4rem;">
                        {% for motCleWidget in searchForm.motsCles %}
                            <label class="kw-tag {% if motCleWidget.vars.checked %}active{% endif %}">
                                {{ form_widget(motCleWidget) }}
                                {{ motCleWidget.vars.label }}
                            </label>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}

                <div class="col-12 d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fas fa-search me-1"></i>Rechercher
                    </button>
                    <button type="button" id="resetFilters" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-redo me-1"></i>Réinitialiser
                    </button>
                </div>
            {{ form_end(searchForm) }}
        </div>
    </div>

    <!-- Grille formations -->
    {% if formations|length > 0 %}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for formation in formations %}
            <div class="col">
                <div class="formation-card" style="background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius); box-shadow:var(--shadow-sm); display:flex; flex-direction:column; height:100%; transition:box-shadow 0.15s, transform 0.15s;">
                    <!-- Top color band -->
                    <div style="height:4px; background:linear-gradient(90deg, var(--clr-primary), var(--clr-primary-dark)); border-radius:var(--radius) var(--radius) 0 0;"></div>

                    <div style="padding:1.25rem; flex:1; display:flex; flex-direction:column;">
                        <!-- Badges -->
                        <div style="display:flex; gap:0.4rem; flex-wrap:wrap; margin-bottom:0.75rem;">
                            {% if formation.theme %}
                                <span style="background:var(--clr-primary-muted); color:var(--clr-primary-dark); font-size:0.68rem; font-weight:700; padding:0.15rem 0.5rem; border-radius:100px; letter-spacing:0.03em;">{{ formation.theme }}</span>
                            {% endif %}
                            {% if formation.niveau %}
                                <span style="background:#EDE9FE; color:#5B21B6; font-size:0.68rem; font-weight:700; padding:0.15rem 0.5rem; border-radius:100px; letter-spacing:0.03em;">{{ formation.niveau }}</span>
                            {% endif %}
                            {% if formation.placesDisponibles > 0 %}
                                <span style="background:#D1FAE5; color:#065F46; font-size:0.68rem; font-weight:700; padding:0.15rem 0.5rem; border-radius:100px;">Disponible</span>
                            {% else %}
                                <span style="background:#FEE2E2; color:#991B1B; font-size:0.68rem; font-weight:700; padding:0.15rem 0.5rem; border-radius:100px;">Complet</span>
                            {% endif %}
                        </div>

                        <!-- Titre -->
                        <h3 style="font-size:0.9375rem; font-weight:700; color:var(--clr-text); margin:0 0 0.5rem; line-height:1.35;">
                            <a href="{{ path('formation_voir', {id: formation.id}) }}" style="color:inherit; text-decoration:none;">
                                {{ formation.titre }}
                            </a>
                        </h3>

                        <!-- Description -->
                        {% if formation.description %}
                        <p style="font-size:0.8rem; color:var(--clr-text-muted); line-height:1.5; margin:0 0 1rem; flex:1;">
                            {{ formation.description|u.truncate(100, '…') }}
                        </p>
                        {% endif %}

                        <!-- Meta -->
                        <div style="display:flex; flex-direction:column; gap:0.4rem; padding:0.875rem; background:var(--clr-bg); border-radius:var(--radius-sm); margin-bottom:1rem;">
                            <div style="display:flex; justify-content:space-between; font-size:0.8rem;">
                                <span style="color:var(--clr-text-muted);"><i class="fas fa-clock me-1"></i>Durée</span>
                                <strong style="color:var(--clr-text);">{{ formation.duree }}h</strong>
                            </div>
                            <div style="display:flex; justify-content:space-between; font-size:0.8rem;">
                                <span style="color:var(--clr-text-muted);"><i class="fas fa-euro-sign me-1"></i>Tarif</span>
                                <strong style="color:var(--clr-primary);">{{ formation.prix }}€</strong>
                            </div>
                            <div style="display:flex; justify-content:space-between; font-size:0.8rem;">
                                <span style="color:var(--clr-text-muted);"><i class="fas fa-users me-1"></i>Places</span>
                                <strong style="color:var(--clr-text);">{{ formation.placesDisponibles }} dispo.</strong>
                            </div>
                            {% if formation.dateDebut %}
                            <div style="display:flex; justify-content:space-between; font-size:0.8rem;">
                                <span style="color:var(--clr-text-muted);"><i class="fas fa-calendar me-1"></i>Début</span>
                                <strong style="color:var(--clr-text);">{{ formation.dateDebut|date('d/m/Y') }}</strong>
                            </div>
                            {% endif %}
                        </div>

                        <!-- CTA -->
                        <div class="d-flex gap-2">
                            <a href="{{ path('formation_voir', {id: formation.id}) }}"
                               class="btn btn-primary btn-sm" style="flex:1; text-align:center;">
                                Voir la formation
                            </a>
                            {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('formation_modifier', {id: formation.id}) }}"
                               style="display:flex; align-items:center; justify-content:center; width:32px; height:32px; border-radius:var(--radius-sm); border:1px solid var(--clr-border); background:var(--clr-surface); color:var(--clr-text-muted); font-size:0.8rem; text-decoration:none;">
                                <i class="fas fa-edit"></i>
                            </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% else %}
        <div style="background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius); padding:4rem 2rem; text-align:center; box-shadow:var(--shadow-sm);">
            <i class="fas fa-search" style="font-size:2.5rem; opacity:0.15; display:block; margin-bottom:1rem;"></i>
            <p style="font-size:0.9375rem; font-weight:600; color:var(--clr-text); margin-bottom:0.5rem;">Aucune formation trouvée</p>
            <p style="font-size:0.85rem; color:var(--clr-text-muted); margin-bottom:1.5rem;">Modifiez vos critères de recherche pour trouver des formations.</p>
            <button type="button" onclick="document.getElementById('resetFilters').click()" class="btn btn-outline-primary btn-sm">
                Réinitialiser les filtres
            </button>
        </div>
    {% endif %}
</div>

<style>
.formation-card:hover {
    box-shadow: var(--shadow-md) !important;
    transform: translateY(-2px);
}
.kw-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--clr-border);
    border-radius: 100px;
    font-size: 0.8rem;
    color: var(--clr-text-muted);
    background: var(--clr-surface);
    cursor: pointer;
    transition: all 0.12s;
    user-select: none;
    font-weight: 500;
}
.kw-tag:hover { border-color: var(--clr-primary); color: var(--clr-primary); background: var(--clr-primary-muted); }
.kw-tag.active { background: var(--clr-primary); border-color: var(--clr-primary); color: white; }
.kw-tag input[type="checkbox"] { position: absolute; opacity: 0; pointer-events: none; }
</style>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Filtre toggle
    var toggle = document.getElementById('filter-toggle');
    var body = document.getElementById('filter-body');
    var chevron = document.getElementById('filter-chevron');
    if (toggle && body) {
        toggle.addEventListener('click', function() {
            var open = body.style.display !== 'none';
            body.style.display = open ? 'none' : 'block';
            chevron.style.transform = open ? 'rotate(180deg)' : 'rotate(0deg)';
        });
    }

    // Mots-clés
    document.querySelectorAll('.kw-tag').forEach(function(tag) {
        var cb = tag.querySelector('input[type="checkbox"]');
        tag.addEventListener('click', function(e) {
            if (e.target !== cb) {
                cb.checked = !cb.checked;
                tag.classList.toggle('active', cb.checked);
            }
        });
    });

    // Reset
    document.getElementById('resetFilters').addEventListener('click', function(e) {
        e.preventDefault();
        document.querySelectorAll('select').forEach(function(s) { s.selectedIndex = 0; });
        document.querySelectorAll('input[type="number"], input[type="text"]').forEach(function(i) { i.value = ''; });
        document.querySelectorAll('.kw-tag input[type="checkbox"]').forEach(function(cb) {
            cb.checked = false;
            cb.closest('.kw-tag').classList.remove('active');
        });
        document.querySelector('form').submit();
    });
});
</script>
{% endblock %}
