{% extends 'base.html.twig' %}

{% block title %}{{ formation.titre }}{% endblock %}

{% block body %}
<div class="container my-4">
    {# Messages flash #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card mb-4">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h1 class="mb-0 h2">{{ formation.titre }}</h1>
            {% if formation.placesDisponibles > 0 %}
                <span class="badge bg-success">{{ formation.placesDisponibles }} places disponibles</span>
            {% else %}
                <span class="badge bg-danger">Complet</span>
            {% endif %}
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <h3>Description</h3>
                    <p class="lead">{{ formation.description }}</p>
                    
                    <h4 class="mt-4">Informations</h4>
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li><i class="fas fa-graduation-cap me-2"></i> <strong>Niveau :</strong> {{ formation.niveau }}</li>
                                <li><i class="fas fa-folder me-2"></i> <strong>Thème :</strong> {{ formation.theme }}</li>
                                <li><i class="fas fa-clock me-2"></i> <strong>Durée :</strong> {{ formation.duree }}h</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-unstyled">
                                <li><i class="fas fa-calendar-alt me-2"></i> <strong>Début :</strong> {{ formation.dateDebut|date('d/m/Y') }}</li>
                                <li><i class="fas fa-calendar-check me-2"></i> <strong>Fin :</strong> {{ formation.dateFin|date('d/m/Y') }}</li>
                                <li><i class="fas fa-tag me-2"></i> <strong>Prix :</strong> {{ formation.prix }}€</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header bg-light">
                            <h4 class="mb-0">Formateur</h4>
                        </div>
                        <div class="card-body">
                            <p><strong>{{ formation.formateur.prenom }} {{ formation.formateur.nom }}</strong></p>
                            <p class="text-muted">{{ formation.formateur.biographie|u.truncate(150, '...') }}</p>
                        </div>
                    </div>
                    
                    {# Ajout du bloc d'inscription pour les utilisateurs connectés #}
                    <div class="card mt-3">
                        <div class="card-header bg-light">
                            <h4 class="mb-0">Inscription</h4>
                        </div>
                        <div class="card-body">
                            {% if is_granted('ROLE_USER') %}
                                {% if inscription is defined and inscription %}
                                    {% if inscription.statut == 'en_attente' %}
                                        <div class="alert alert-warning">
                                            <i class="fas fa-clock me-2"></i>Votre demande d'inscription est en attente de validation.
                                        </div>
                                        <a href="{{ path('inscription_details', {id: inscription.id}) }}" class="btn btn-warning w-100">
                                            <i class="fas fa-eye me-1"></i>Voir ma demande
                                        </a>
                                        <a href="{{ path('inscription_annuler', {id: inscription.id}) }}" class="btn btn-outline-danger w-100 mt-2" onclick="return confirm('Êtes-vous sûr de vouloir annuler cette demande d\'inscription ?')">
                                            <i class="fas fa-times me-1"></i>Annuler ma demande
                                        </a>
                                    {% elseif inscription.statut == 'acceptee' %}
                                        <div class="alert alert-success">
                                            <i class="fas fa-check-circle me-2"></i>Vous êtes inscrit à cette formation.
                                        </div>
                                        <a href="{{ path('inscription_details', {id: inscription.id}) }}" class="btn btn-success w-100">
                                            <i class="fas fa-eye me-1"></i>Voir les détails
                                        </a>
                                    {% elseif inscription.statut == 'refusee' %}
                                        <div class="alert alert-danger">
                                            <i class="fas fa-times-circle me-2"></i>Votre demande a été refusée.
                                            {% if inscription.motif %}
                                                <p class="mt-2 mb-0"><strong>Motif :</strong> {{ inscription.motif }}</p>
                                            {% endif %}
                                        </div>
                                        <a href="{{ path('inscription_demande', {id: formation.id}) }}" class="btn btn-outline-primary w-100">
                                            <i class="fas fa-redo me-1"></i>Faire une nouvelle demande
                                        </a>
                                    {% endif %}
                                {% else %}
                                    {% if complet %}
                                        <div class="alert alert-danger">
                                            <i class="fas fa-ban me-2"></i>Cette formation est complète.
                                        </div>
                                        <button class="btn btn-secondary w-100" disabled>
                                            <i class="fas fa-user-plus me-1"></i>S'inscrire
                                        </button>
                                    {% else %}
                                        <p>Intéressé(e) par cette formation ? Inscrivez-vous dès maintenant !</p>
                                        <a href="{{ path('inscription_demande', {id: formation.id}) }}" class="btn btn-primary w-100">
                                            <i class="fas fa-user-plus me-1"></i>S'inscrire
                                        </a>
                                    {% endif %}
                                {% endif %}
                            {% else %}
                                <p>Connectez-vous pour vous inscrire à cette formation.</p>
                                <a href="{{ path('app_login') }}" class="btn btn-outline-primary w-100">
                                    <i class="fas fa-sign-in-alt me-1"></i>Se connecter
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            {% if is_granted('ROLE_FORMATEUR') or is_granted('ROLE_ADMIN') %}
                {# Section documents #}
                <div class="mt-4">
                    <h4>Documents pédagogiques</h4>
                    {% if formation.documents|length > 0 %}
                        <div class="list-group">
                            {% for document in formation.documents %}
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <i class="fas fa-file-{{ document.extension|default('alt') }} me-2"></i>
                                        {{ document.nom }}
                                    </div>
                                    <div>
                                        <a href="{{ path('document_telecharger', {'id': document.id}) }}" 
                                           class="btn btn-sm btn-primary me-2">
                                            <i class="fas fa-download"></i>
                                        </a>
                                        {% if is_granted('ROLE_ADMIN') %}
                                            <a href="{{ path('formation_document_supprimer', {'id': document.id}) }}" 
                                               class="btn btn-sm btn-danger"
                                               onclick="return confirm('Êtes-vous sûr de vouloir supprimer ce document ?')">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="alert alert-info">
                            Aucun document n'est disponible pour le moment.
                        </div>
                    {% endif %}
                </div>
            {% endif %}
        </div>
        
        {# Section pour les participants inscrits (visible uniquement par les formateurs et admin) #}
        {% if is_granted('ROLE_FORMATEUR') or is_granted('ROLE_ADMIN') %}
            <div class="card-footer bg-white">
                <h4>Participants inscrits</h4>
                {% set inscriptions_acceptees = formation.inscriptions|filter(i => i.statut == 'acceptee') %}
                
                {% if inscriptions_acceptees|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Participant</th>
                                    <th>Email</th>
                                    <th>Date d'inscription</th>
                                    <th>Statut</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for inscription in inscriptions_acceptees %}
                                    <tr>
                                        <td>{{ inscription.utilisateur.prenom }} {{ inscription.utilisateur.nom }}</td>
                                        <td>{{ inscription.utilisateur.email }}</td>
                                        <td>{{ inscription.dateConfirmation|date('d/m/Y') }}</td>
                                        <td>
                                            {% if inscription.estTerminee %}
                                                <span class="badge bg-info">Terminée</span>
                                            {% else %}
                                                <span class="badge bg-success">En cours</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <a href="{{ path('inscription_details', {id: inscription.id}) }}" class="btn btn-sm btn-outline-info">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            {% if not inscription.estTerminee %}
                                                <a href="{{ path('inscription_terminer', {id: inscription.id}) }}" class="btn btn-sm btn-outline-success" onclick="return confirm('Marquer cette formation comme terminée pour ce participant ?')">
                                                    <i class="fas fa-check"></i>
                                                </a>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="alert alert-info">
                        Aucun participant inscrit pour le moment.
                    </div>
                {% endif %}
                
                {# Demandes en attente #}
                {% set inscriptions_attente = formation.inscriptions|filter(i => i.statut == 'en_attente') %}
                {% if inscriptions_attente|length > 0 %}
                    <h5 class="mt-4">Demandes en attente ({{ inscriptions_attente|length }})</h5>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Participant</th>
                                    <th>Date de demande</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for inscription in inscriptions_attente %}
                                    <tr>
                                        <td>{{ inscription.utilisateur.prenom }} {{ inscription.utilisateur.nom }}</td>
                                        <td>{{ inscription.dateInscription|date('d/m/Y') }}</td>
                                        <td>
                                            <a href="{{ path('inscription_valider', {id: inscription.id}) }}" class="btn btn-sm btn-primary">
                                                <i class="fas fa-check me-1"></i>Traiter
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        {% endif %}
    </div>

    <div class="d-flex justify-content-between">
        <a href="{{ path('formation_lister') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left me-1"></i> Retour à la liste
        </a>
        
        <div>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('formation_modifier', {'id': formation.id}) }}" class="btn btn-warning me-2">
                    <i class="fas fa-edit me-1"></i> Modifier
                </a>
                <a href="{{ path('formation_supprimer', {'id': formation.id}) }}" 
                   class="btn btn-danger"
                   onclick="return confirm('Êtes-vous sûr de vouloir supprimer cette formation ?')">
                    <i class="fas fa-trash me-1"></i> Supprimer
                </a>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}