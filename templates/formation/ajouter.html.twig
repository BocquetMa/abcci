{% extends 'base.html.twig' %}

{% block title %}Ajouter une formation{% endblock %}

{% block body %}
<div class="fr-container fr-mt-4w fr-mb-6w">
    <h1 class="fr-h2 fr-mb-3w">Créer une formation</h1>

    <div class="fr-card fr-p-3w">
        {{ form_start(form) }}

        <div class="fr-grid-row fr-grid-row--gutters">
            <div class="fr-col-12 fr-col-md-6">
                {{ form_row(form.titre, {'label': 'Titre', 'attr': {'class': 'fr-input'}}) }}
                {{ form_row(form.description, {'label': 'Description', 'attr': {'class': 'fr-input', 'rows': 4}}) }}
                {{ form_row(form.theme, {'label': 'Thème', 'attr': {'class': 'fr-select'}}) }}
                {{ form_row(form.niveau, {'label': 'Niveau', 'attr': {'class': 'fr-select'}}) }}
            </div>
            <div class="fr-col-12 fr-col-md-6">
                {{ form_row(form.duree, {'label': 'Durée (heures)', 'attr': {'class': 'fr-input'}}) }}
                {{ form_row(form.prix, {'label': 'Prix (€)', 'attr': {'class': 'fr-input'}}) }}
                {{ form_row(form.dateDebut, {'label': 'Date de début', 'attr': {'class': 'fr-input', 'type': 'date'}}) }}
                {{ form_row(form.dateFin, {'label': 'Date de fin', 'attr': {'class': 'fr-input', 'type': 'date'}}) }}
                {{ form_row(form.nombrePlacesTotal, {'label': 'Nombre de places', 'attr': {'class': 'fr-input'}}) }}
            </div>
        </div>

        {% if form.formateur is defined %}
            <div class="fr-mt-2w">
                {{ form_row(form.formateur, {'label': 'Formateur', 'attr': {'class': 'fr-select'}}) }}
            </div>
        {% endif %}

        {% if form.motsCles is defined %}
            <div class="fr-mt-2w">
                {{ form_row(form.motsCles) }}
            </div>
        {% endif %}

        <div class="d-flex justify-content-between fr-mt-4w">
            <a href="{{ path('formateur_mes_formations') }}" class="fr-btn fr-btn--secondary">
                Retour
            </a>
            <button type="submit" class="fr-btn">
                Créer la formation
            </button>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
