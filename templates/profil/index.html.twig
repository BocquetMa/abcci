{# templates/profil/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Mon profil - {{ parent() }}{% endblock %}

{% block body %}
<div class="container my-4">
    <div class="row">
        <div class="col-md-3">
            {% include 'profil/_sidebar.html.twig' with {active: 'index'} %}
        </div>
        <div class="col-md-9">
            <div class="card mb-4">
                <div class="card-header">
                    <h2 class="mb-0">Mon profil</h2>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-4 text-center">
                            {% if user.photo is defined and user.photo %}
                                <img src="{{ asset('uploads/photos/' ~ user.photo) }}" alt="Photo de profil" class="img-fluid rounded-circle mb-3" style="max-width: 150px;">
                            {% else %}
                                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 150px; height: 150px;">
                                    <i class="fas fa-user fa-4x text-secondary"></i>
                                </div>
                            {% endif %}
                            <h4>{{ user.prenom }} {{ user.nom }}</h4>
                            <p class="text-muted">{{ user.email }}</p>
                        </div>
                        <div class="col-md-8">
                            <div class="row mb-3">
                                <div class="col-md-6 mb-3">
                                    <div class="card bg-light">
                                        <div class="card-body text-center">
                                            <h1 class="display-4">{% if user.niveau is defined %}{{ user.niveau }}{% else %}1{% endif %}</h1>
                                            <p class="text-muted mb-0">Niveau actuel</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <div class="card bg-light">
                                        <div class="card-body text-center">
                                            <h1 class="display-4">{% if user.points is defined %}{{ user.points }}{% else %}0{% endif %}</h1>
                                            <p class="text-muted mb-0">Points accumulés</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="mb-0">Progression</h5>
                                </div>
                                <div class="card-body">
                                    <div class="progress mb-3">
                                        {% set progression = 25 %}
                                        <div class="progress-bar bg-success" role="progressbar" style="width: {{ progression }}%;" aria-valuenow="{{ progression }}" aria-valuemin="0" aria-valuemax="100">{{ progression }}%</div>
                                    </div>
                                    <p class="text-center text-muted">Encore quelques points pour passer au niveau suivant</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    {# Affichage des badges récents #}
                    {% if badges_recents is defined and badges_recents|length > 0 %}
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">Mes badges récents</h5>
                                <a href="{{ path('profil_badges') }}" class="btn btn-sm btn-outline-primary">Voir tous mes badges</a>
                            </div>
                            <div class="card-body">
                                <div class="row row-cols-2 row-cols-md-5 g-3">
                                    {% for badge in badges_recents %}
                                        <div class="col text-center">
                                            <a href="{{ path('profil_badge_details', {id: badge.id}) }}" class="text-decoration-none">
                                                <img src="{{ asset(badge.image) }}" alt="{{ badge.nom }}" class="img-fluid mb-2" style="max-height: 60px;">
                                                <p class="small text-truncate mb-0">{{ badge.nom }}</p>
                                                <small class="text-muted">{{ badge.obtenuLe|date('d/m/Y') }}</small>
                                            </a>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
            
            {# Autres informations du profil #}
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Mes statistiques</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 text-center mb-3">
                            <div class="bg-light rounded p-3">
                                <i class="fas fa-graduation-cap fa-2x text-primary mb-2"></i>
                                <h4>{% if user.formationsCompletees is defined %}{{ user.formationsCompletees }}{% else %}0{% endif %}</h4>
                                <p class="text-muted mb-0">Formations complétées</p>
                            </div>
                        </div>
                        <div class="col-md-4 text-center mb-3">
                            <div class="bg-light rounded p-3">
                                <i class="fas fa-tasks fa-2x text-success mb-2"></i>
                                <h4>{% if user.quizReussis is defined %}{{ user.quizReussis }}{% else %}0{% endif %}</h4>
                                <p class="text-muted mb-0">Quiz réussis</p>
                            </div>
                        </div>
                        <div class="col-md-4 text-center mb-3">
                            <div class="bg-light rounded p-3">
                                <i class="fas fa-award fa-2x text-warning mb-2"></i>
                                <h4>{% if badges_recents is defined %}{{ badges_recents|length }}{% else %}0{% endif %}</h4>
                                <p class="text-muted mb-0">Badges obtenus</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}