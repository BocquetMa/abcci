{% extends 'base.html.twig' %}
{% block title %}Mon profil - ABCCI{% endblock %}

{% block body %}
<div class="container" style="max-width:1100px; padding:2rem 1.5rem;">
    <div class="row g-4">

        <!-- Sidebar -->
        <div class="col-md-3">
            {% include 'profil/_sidebar.html.twig' with {active: 'index'} %}
        </div>

        <!-- Contenu -->
        <div class="col-md-9">

            <!-- Carte principale -->
            <div style="background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius); padding:1.75rem; box-shadow:var(--shadow-sm); margin-bottom:1.25rem;">
                <div class="row align-items-center g-3">
                    <div class="col-auto">
                        {% if user.photo %}
                            <img src="{{ asset('uploads/photos/' ~ user.photo) }}" alt="Photo"
                                 style="width:96px; height:96px; border-radius:50%; object-fit:cover; border:3px solid var(--clr-primary-light);">
                        {% else %}
                            <div style="width:96px; height:96px; border-radius:50%; background:linear-gradient(135deg,var(--clr-primary),var(--clr-primary-dark)); display:flex; align-items:center; justify-content:center; font-size:2rem; font-weight:700; color:white;">
                                {{ user.prenom|first|upper }}{{ user.nom|first|upper }}
                            </div>
                        {% endif %}
                    </div>
                    <div class="col">
                        <h2 style="font-size:1.25rem; font-weight:700; color:var(--clr-text); margin:0 0 0.25rem;">{{ user.prenom }} {{ user.nom }}</h2>
                        <p style="font-size:0.85rem; color:var(--clr-text-muted); margin:0 0 0.5rem;">{{ user.email }}</p>
                        {% for role in user.roles %}
                            {% if role != 'ROLE_USER' %}
                                <span style="background:var(--clr-primary-muted); color:var(--clr-primary-dark); font-size:0.7rem; font-weight:700; padding:0.2rem 0.65rem; border-radius:100px; letter-spacing:0.04em; margin-right:0.25rem;">{{ role|replace({'ROLE_': ''}) }}</span>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <div class="col-auto">
                        <a href="{{ path('profil_modifier') }}" class="btn btn-outline-primary btn-sm">
                            <i class="fas fa-edit me-1"></i>Modifier
                        </a>
                    </div>
                </div>
            </div>

            <!-- Stats -->
            <div class="row g-3 mb-4">
                <div class="col-sm-4">
                    <div style="background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius); padding:1.25rem; text-align:center; box-shadow:var(--shadow-sm);">
                        <div style="font-size:2rem; font-weight:700; color:var(--clr-primary);">{{ user.inscriptions|length }}</div>
                        <div style="font-size:0.8rem; color:var(--clr-text-muted); margin-top:0.25rem;">Inscriptions</div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div style="background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius); padding:1.25rem; text-align:center; box-shadow:var(--shadow-sm);">
                        <div style="font-size:2rem; font-weight:700; color:var(--clr-primary);">{{ user.points ?? 0 }}</div>
                        <div style="font-size:0.8rem; color:var(--clr-text-muted); margin-top:0.25rem;">Points</div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div style="background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius); padding:1.25rem; text-align:center; box-shadow:var(--shadow-sm);">
                        <div style="font-size:2rem; font-weight:700; color:var(--clr-primary);">{{ user.niveau ?? 'Débutant' }}</div>
                        <div style="font-size:0.8rem; color:var(--clr-text-muted); margin-top:0.25rem;">Niveau</div>
                    </div>
                </div>
            </div>

            <!-- Badges récents -->
            {% if badges_recents is defined and badges_recents|length > 0 %}
            <div style="background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius); padding:1.5rem; box-shadow:var(--shadow-sm); margin-bottom:1.25rem;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 style="font-size:0.9375rem; font-weight:700; color:var(--clr-text); margin:0;">
                        <i class="fas fa-award me-2" style="color:var(--clr-primary);"></i>Badges récents
                    </h3>
                    <a href="{{ path('profil_badges') }}" class="btn btn-sm btn-outline-primary">Voir tous</a>
                </div>
                <div class="row g-3">
                    {% for badge in badges_recents %}
                    <div class="col-auto text-center">
                        <a href="{{ path('profil_badge_details', {id: badge.id}) }}" style="text-decoration:none; display:block;">
                            <img src="{{ asset(badge.image) }}" alt="{{ badge.nom }}" style="max-height:48px; object-fit:contain; display:block; margin:0 auto 0.4rem;">
                            <div style="font-size:0.78rem; font-weight:600; color:var(--clr-text);">{{ badge.nom }}</div>
                            <div style="font-size:0.7rem; color:var(--clr-text-muted);">{{ badge.obtenuLe|date('d/m/Y') }}</div>
                        </a>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            <!-- Biographie -->
            {% if user.biographie %}
            <div style="background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius); padding:1.5rem; box-shadow:var(--shadow-sm);">
                <h3 style="font-size:0.9375rem; font-weight:700; color:var(--clr-text); margin:0 0 0.75rem;">
                    <i class="fas fa-align-left me-2" style="color:var(--clr-primary);"></i>À propos
                </h3>
                <p style="font-size:0.875rem; color:var(--clr-text-muted); line-height:1.6; margin:0;">{{ user.biographie }}</p>
            </div>
            {% endif %}

        </div>
    </div>
</div>
{% endblock %}
