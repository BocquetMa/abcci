{# templates/profil/_sidebar.html.twig #}
<aside class="profil-sidebar">
    <!-- Carte utilisateur -->
    <div class="profil-user-card">
        <div class="profil-avatar">
            {% if app.user.photo %}
                <img src="{{ asset('uploads/photos/' ~ app.user.photo) }}" alt="Photo de profil">
            {% else %}
                {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
            {% endif %}
        </div>
        <div class="profil-user-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
        <div class="profil-user-email">{{ app.user.email }}</div>
        <div class="profil-user-level">
            <span class="profil-level-badge">{{ app.user.niveau ?? 'Débutant' }}</span>
            <span class="profil-points">{{ app.user.points ?? 0 }} pts</span>
        </div>
        <div class="profil-progress-bar">
            <div class="profil-progress-fill" style="width: 25%;"></div>
        </div>
    </div>

    <!-- Navigation -->
    <nav class="profil-nav">
        <a href="{{ path('profil_index') }}"
           class="profil-nav-link {{ active is defined and active == 'index' ? 'active' : '' }}">
            <i class="fas fa-user"></i>
            <span>Mon profil</span>
        </a>
        <a href="{{ path('profil_badges') }}"
           class="profil-nav-link {{ active is defined and active == 'badges' ? 'active' : '' }}">
            <i class="fas fa-award"></i>
            <span>Mes badges</span>
        </a>
        <a href="{{ path('profil_planning') }}"
           class="profil-nav-link {{ active is defined and active == 'planning' ? 'active' : '' }}">
            <i class="fas fa-calendar-alt"></i>
            <span>Mon planning</span>
        </a>
        <a href="{{ path('profil_inscriptions') }}"
           class="profil-nav-link {{ active is defined and active == 'inscriptions' ? 'active' : '' }}">
            <i class="fas fa-clipboard-list"></i>
            <span>Mes inscriptions</span>
        </a>
        <a href="{{ path('profil_modifier') }}"
           class="profil-nav-link {{ active is defined and active == 'modifier' ? 'active' : '' }}">
            <i class="fas fa-edit"></i>
            <span>Modifier mon profil</span>
        </a>
        <a href="{{ path('formation_lister') }}" class="profil-nav-link">
            <i class="fas fa-book-open"></i>
            <span>Formations disponibles</span>
        </a>
    </nav>
</aside>

<style>
.profil-sidebar {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.profil-user-card {
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius);
    padding: 1.5rem 1.25rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
}

.profil-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--clr-primary), var(--clr-primary-dark));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 700;
    color: white;
    margin: 0 auto 0.875rem;
    overflow: hidden;
}
.profil-avatar img { width: 100%; height: 100%; object-fit: cover; }

.profil-user-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--clr-text);
    margin-bottom: 0.2rem;
}
.profil-user-email {
    font-size: 0.775rem;
    color: var(--clr-text-muted);
    margin-bottom: 0.75rem;
}
.profil-user-level {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
}
.profil-level-badge {
    background: var(--clr-primary-muted);
    color: var(--clr-primary-dark);
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    letter-spacing: 0.03em;
}
.profil-points {
    font-size: 0.78rem;
    color: var(--clr-text-muted);
    font-weight: 500;
}
.profil-progress-bar {
    height: 5px;
    background: var(--clr-border);
    border-radius: 3px;
    overflow: hidden;
}
.profil-progress-fill {
    height: 100%;
    background: var(--clr-primary);
    border-radius: 3px;
}

.profil-nav {
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    padding: 0.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
}
.profil-nav-link {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.65rem 0.875rem;
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--clr-text);
    text-decoration: none;
    transition: background 0.12s, color 0.12s;
}
.profil-nav-link i {
    width: 16px;
    font-size: 0.82rem;
    color: var(--clr-text-muted);
    flex-shrink: 0;
}
.profil-nav-link:hover { background: var(--clr-bg); color: var(--clr-primary); }
.profil-nav-link:hover i { color: var(--clr-primary); }
.profil-nav-link.active { background: var(--clr-primary-muted); color: var(--clr-primary); font-weight: 600; }
.profil-nav-link.active i { color: var(--clr-primary); }
</style>
