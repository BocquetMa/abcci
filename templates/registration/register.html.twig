{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .register-container {
            max-width: 600px;
            margin: 2rem auto;
        }
        .card-header {
            background-color: #28a745;
            color: white;
        }
        .required:after {
            content: " *";
            color: red;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container register-container">
    <div class="card shadow">
        <div class="card-header">
            <h3 class="text-center mb-0">Créer un compte</h3>
        </div>
        <div class="card-body">
            {% for flash_error in app.flashes('verify_email_error') %}
                <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
            {% endfor %}

            {{ form_start(registrationForm, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            {{ form_label(registrationForm.nom, null, {'label_attr': {'class': 'required'}}) }}
                            {{ form_widget(registrationForm.nom, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.nom) }}
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            {{ form_label(registrationForm.prenom, null, {'label_attr': {'class': 'required'}}) }}
                            {{ form_widget(registrationForm.prenom, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(registrationForm.prenom) }}
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3">
                    {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'required'}}) }}
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(registrationForm.email) }}
                </div>

                <div class="form-group mb-3">
                    {{ form_label(registrationForm.telephone) }}
                    {{ form_widget(registrationForm.telephone, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(registrationForm.telephone) }}
                </div>

                <div class="form-group mb-3">
                    {{ form_label(registrationForm.plainPassword, 'Mot de passe', {'label_attr': {'class': 'required'}}) }}
                    {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control'}}) }}
                    <div class="form-text">
                        Le mot de passe doit contenir au moins 8 caractères, une majuscule, 
                        une minuscule et un chiffre.
                    </div>
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>

                {% if registrationForm.agreeTerms is defined %}
                    <div class="form-check mb-3">
                        {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                        {{ form_label(registrationForm.agreeTerms, 'J\'accepte les conditions d\'utilisation', {'label_attr': {'class': 'form-check-label'}}) }}
                        {{ form_errors(registrationForm.agreeTerms) }}
                    </div>
                {% endif %}

                <button type="submit" class="btn btn-success w-100">
                    <i class="fas fa-user-plus me-2"></i>S'inscrire
                </button>
            {{ form_end(registrationForm) }}
        </div>
        <div class="card-footer text-center">
            <p class="mb-0">
                Vous avez déjà un compte ? 
                <a href="{{ path('app_login') }}" class="text-decoration-none">
                    <i class="fas fa-sign-in-alt me-1"></i>Connectez-vous
                </a>
            </p>
        </div>
    </div>
</div>

{% block javascripts %}
    {{ parent() }}
    <script>
        // Validation côté client
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms).forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
        })()
    </script>
{% endblock %}
{% endblock %}