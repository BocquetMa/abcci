<aside style="display:flex; flex-direction:column; gap:0.75rem;">
    <div style="background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius); padding:1.5rem 1.25rem; text-align:center; box-shadow:var(--shadow-sm);">
        <div style="width:56px; height:56px; border-radius:50%; background:linear-gradient(135deg,var(--clr-primary),var(--clr-primary-dark)); display:flex; align-items:center; justify-content:center; font-size:1rem; font-weight:700; color:white; margin:0 auto 0.75rem; overflow:hidden;">
            {% if app.user.photo %}
                <img src="{{ asset('uploads/photos/' ~ app.user.photo) }}" style="width:100%;height:100%;object-fit:cover;" alt="">
            {% else %}
                {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
            {% endif %}
        </div>
        <div style="font-size:0.9rem; font-weight:700; color:var(--clr-text);">{{ app.user.prenom }} {{ app.user.nom }}</div>
        <div style="font-size:0.75rem; color:var(--clr-text-muted); margin-top:0.15rem;">Formateur</div>
    </div>

    <nav style="background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius); box-shadow:var(--shadow-sm); padding:0.4rem; display:flex; flex-direction:column; gap:0.1rem;">
        <a href="{{ path('formateur_mes_formations') }}"
           style="display:flex; align-items:center; gap:0.65rem; padding:0.65rem 0.875rem; border-radius:var(--radius-sm); font-size:0.875rem; font-weight:500; color:{{ active is defined and active == 'formations' ? 'var(--clr-primary)' : 'var(--clr-text)' }}; text-decoration:none; background:{{ active is defined and active == 'formations' ? 'var(--clr-primary-muted)' : 'transparent' }};">
            <i class="fas fa-chalkboard-teacher" style="width:16px; font-size:0.82rem; color:{{ active is defined and active == 'formations' ? 'var(--clr-primary)' : 'var(--clr-text-muted)' }};"></i>
            Mes formations
        </a>
        <a href="{{ path('inscription_formateur_en_attente') }}"
           style="display:flex; align-items:center; gap:0.65rem; padding:0.65rem 0.875rem; border-radius:var(--radius-sm); font-size:0.875rem; font-weight:500; color:{{ active is defined and active == 'inscriptions_attente' ? 'var(--clr-primary)' : 'var(--clr-text)' }}; text-decoration:none; background:{{ active is defined and active == 'inscriptions_attente' ? 'var(--clr-primary-muted)' : 'transparent' }};">
            <i class="fas fa-user-clock" style="width:16px; font-size:0.82rem; color:{{ active is defined and active == 'inscriptions_attente' ? 'var(--clr-primary)' : 'var(--clr-text-muted)' }};"></i>
            Inscriptions en attente
        </a>
        <a href="{{ path('inscription_formateur_liste') }}"
           style="display:flex; align-items:center; gap:0.65rem; padding:0.65rem 0.875rem; border-radius:var(--radius-sm); font-size:0.875rem; font-weight:500; color:{{ active is defined and active == 'inscriptions' ? 'var(--clr-primary)' : 'var(--clr-text)' }}; text-decoration:none; background:{{ active is defined and active == 'inscriptions' ? 'var(--clr-primary-muted)' : 'transparent' }};">
            <i class="fas fa-users" style="width:16px; font-size:0.82rem; color:{{ active is defined and active == 'inscriptions' ? 'var(--clr-primary)' : 'var(--clr-text-muted)' }};"></i>
            Toutes les inscriptions
        </a>
        <a href="{{ path('quiz_admin_liste') }}"
           style="display:flex; align-items:center; gap:0.65rem; padding:0.65rem 0.875rem; border-radius:var(--radius-sm); font-size:0.875rem; font-weight:500; color:{{ active is defined and active == 'quiz' ? 'var(--clr-primary)' : 'var(--clr-text)' }}; text-decoration:none; background:{{ active is defined and active == 'quiz' ? 'var(--clr-primary-muted)' : 'transparent' }};">
            <i class="fas fa-question-circle" style="width:16px; font-size:0.82rem; color:{{ active is defined and active == 'quiz' ? 'var(--clr-primary)' : 'var(--clr-text-muted)' }};"></i>
            Mes quiz
        </a>
    </nav>
</aside>
