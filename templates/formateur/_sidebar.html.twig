{# templates/formateur/_sidebar.html.twig #}
<div class="list-group mb-4">
    <a href="{{ path('formateur_lister') }}" class="list-group-item list-group-item-action {% if active is defined and active == 'dashboard' %}active{% endif %}">
        <i class="fas fa-tachometer-alt me-2"></i>Tableau de bord
    </a>
    <a href="{{ path('formateur_lister') }}" class="list-group-item list-group-item-action {% if active is defined and active == 'formations' %}active{% endif %}">
        <i class="fas fa-chalkboard-teacher me-2"></i>Mes formations
    </a>
    <a href="{{ path('quiz_admin_liste') }}" class="list-group-item list-group-item-action {% if active is defined and active == 'quiz' %}active{% endif %}">
        <i class="fas fa-question-circle me-2"></i>Mes quiz
    </a>
    <a href="{{ path('inscription_formateur_liste') }}" class="list-group-item list-group-item-action {% if active is defined and active == 'inscriptions' %}active{% endif %}">
        <i class="fas fa-users me-2"></i>Toutes les inscriptions
    </a>
    <a href="{{ path('inscription_formateur_en_attente') }}" class="list-group-item list-group-item-action {% if active is defined and active == 'inscriptions_attente' %}active{% endif %}">
        <i class="fas fa-user-clock me-2"></i>Inscriptions en attente
        <span class="badge bg-danger float-end" id="inscriptions-count"></span>
    </a>
</div>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Statistiques</h5>
    </div>
    <div class="card-body">
        <div class="row text-center">
            <div class="col">
                <h4 id="formations-count">-</h4>
                <small class="text-muted">Formations</small>
            </div>
            <div class="col">
                <h4 id="participants-count">-</h4>
                <small class="text-muted">Participants</small>
            </div>
            <div class="col">
                <h4 id="taux-remplissage">-</h4>
                <small class="text-muted">Remplissage</small>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Fonction pour charger les statistiques (à implémenter)
        function loadStatistics() {
            // Cette fonction pourrait faire un appel AJAX pour récupérer les statistiques
            // Pour l'instant, utilisons des valeurs statiques
            document.getElementById('formations-count').textContent = '{{ app.user.formations|length }}';
            document.getElementById('participants-count').textContent = '-';
            document.getElementById('taux-remplissage').textContent = '-';
            
            // Récupérer le nombre d'inscriptions en attente
            {% if app.user.formations is defined and app.user.formations|length > 0 %}
                fetch('{{ path("inscription_formateur_count_en_attente") }}')
                    .then(response => response.json())
                    .then(data => {
                        const count = data.count;
                        if (count > 0) {
                            document.getElementById('inscriptions-count').textContent = count;
                        } else {
                            document.getElementById('inscriptions-count').style.display = 'none';
                        }
                    });
            {% endif %}
        }
        
        // Charger les statistiques au chargement de la page
        loadStatistics();
    });
</script>