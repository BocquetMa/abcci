{% extends 'base.html.twig' %}
{% block title %}Mes formations - ABCCI{% endblock %}

{% block body %}
<div class="container" style="max-width:1200px; padding:2rem 1.5rem;">
    <div class="row g-4">
        <div class="col-md-3">
            {% include 'formateur/_sidebar.html.twig' with {active: 'formations'} %}
        </div>
        <div class="col-md-9">
            <div style="background:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--radius); padding:1.5rem; box-shadow:var(--shadow-sm);">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h2 style="font-size:1rem; font-weight:700; color:var(--clr-text); margin:0;">
                        <i class="fas fa-chalkboard-teacher me-2" style="color:var(--clr-primary);"></i>Mes formations
                    </h2>
                    {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('formation_ajouter') }}" class="btn btn-primary btn-sm">
                        <i class="fas fa-plus me-1"></i>Créer une formation
                    </a>
                    {% endif %}
                </div>

                {% if formations|length > 0 %}
                <div style="display:flex; flex-direction:column; gap:0.75rem;">
                    {% for formation in formations %}
                    <div style="background:var(--clr-bg); border:1px solid var(--clr-border); border-radius:var(--radius); padding:1.25rem;">
                        <div class="d-flex align-items-start justify-content-between gap-3">
                            <div style="flex:1; min-width:0;">
                                <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                                    <h3 style="font-size:0.9375rem; font-weight:600; color:var(--clr-text); margin:0;">{{ formation.titre }}</h3>
                                    {% if formation.theme %}
                                        <span style="background:var(--clr-primary-muted); color:var(--clr-primary-dark); font-size:0.7rem; font-weight:600; padding:0.15rem 0.5rem; border-radius:100px;">{{ formation.theme }}</span>
                                    {% endif %}
                                    {% if formation.niveau %}
                                        <span style="background:#EDE9FE; color:#5B21B6; font-size:0.7rem; font-weight:600; padding:0.15rem 0.5rem; border-radius:100px;">{{ formation.niveau }}</span>
                                    {% endif %}
                                </div>
                                {% if formation.description %}
                                <p style="font-size:0.8rem; color:var(--clr-text-muted); margin:0 0 0.75rem; line-height:1.5;">{{ formation.description|slice(0,120) }}{% if formation.description|length > 120 %}…{% endif %}</p>
                                {% endif %}
                                <div style="display:flex; gap:1rem; flex-wrap:wrap; font-size:0.78rem; color:var(--clr-text-muted);">
                                    {% if formation.dateDebut is defined and formation.dateDebut %}
                                        <span><i class="fas fa-calendar me-1"></i>{{ formation.dateDebut|date('d/m/Y') }} → {{ formation.dateFin|date('d/m/Y') }}</span>
                                    {% endif %}
                                    <span><i class="fas fa-users me-1"></i>{{ formation.placesOccupees }}/{{ formation.nombrePlacesTotal }} places</span>
                                    {% if formation.prix is defined %}
                                        <span><i class="fas fa-tag me-1"></i>{{ formation.prix }}€</span>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="d-flex flex-column gap-1" style="flex-shrink:0;">
                                <a href="{{ path('formation_voir', {id: formation.id}) }}"
                                   style="font-size:0.78rem; color:var(--clr-primary); font-weight:500; text-decoration:none; white-space:nowrap;">
                                    <i class="fas fa-eye me-1"></i>Voir
                                </a>
                                {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('formation_modifier', {id: formation.id}) }}"
                                   style="font-size:0.78rem; color:var(--clr-text-muted); font-weight:500; text-decoration:none; white-space:nowrap;">
                                    <i class="fas fa-edit me-1"></i>Modifier
                                </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
                {% else %}
                <div style="text-align:center; padding:3rem 1rem; color:var(--clr-text-muted);">
                    <i class="fas fa-chalkboard-teacher" style="font-size:2.5rem; opacity:0.2; display:block; margin-bottom:1rem;"></i>
                    <p style="font-size:0.9375rem; font-weight:600; color:var(--clr-text); margin-bottom:0.5rem;">Aucune formation</p>
                    <p style="font-size:0.85rem; margin-bottom:1.5rem;">Vous n'avez pas encore de formations assignées.</p>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
